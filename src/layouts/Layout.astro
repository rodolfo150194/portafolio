---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
}
const { title = 'Rodolfo García Maeso — Full Stack Developer' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Full Stack Developer portfolio — Rodolfo García Maeso. Python, Django, Next.js, FastAPI, Flutter and more." />
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500;700&family=Barlow+Condensed:ital,wght@0,700;0,800;0,900;1,800&family=Space+Mono:wght@400;700&family=Bebas+Neue&display=swap" rel="stylesheet" />
    <!-- FontAwesome CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <ClientRouter />
    <!-- Anti-FOUC: reads localStorage before first paint to avoid flash -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme') || 'dark';
        if (t === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="bg-white dark:bg-gray-950 font-body">

    <!-- ── Theme Toggle ────────────────────────────────── -->
    <button
      id="theme-toggle"
      aria-label="Toggle theme"
      class="fixed top-4 right-[7.5rem] z-[100] flex items-center justify-center w-[2.625rem] h-[2.375rem] rounded-lg
             bg-white/90 dark:bg-gray-900/90 border border-gray-200 dark:border-white/20 backdrop-blur-md
             text-gray-700 dark:text-white shadow-lg
             hover:border-primary/60 hover:text-primary
             transition-all duration-300"
    >
      <i id="theme-icon" class="fa-solid fa-sun text-base transition-transform duration-300"></i>
    </button>

    <!-- ── Language Toggle ─────────────────────────────── -->
    <button
      id="lang-toggle"
      aria-label="Switch language"
      class="fixed top-4 right-4 z-[100] flex items-center gap-2 px-3 py-2 rounded-lg
             bg-gray-900/90 border border-white/20 backdrop-blur-md
             text-white text-sm font-semibold shadow-lg
             hover:border-primary/60 hover:text-primary
             transition-all duration-300 group select-none"
    >
      <i class="fa-solid fa-globe text-primary text-base transition-transform duration-300 group-hover:rotate-12"></i>
      <span id="lang-label" class="tracking-widest text-xs uppercase">EN</span>
      <i class="fa-solid fa-chevron-down text-[10px] text-slate-400 transition-transform duration-300 group-hover:-rotate-180"></i>
    </button>

    <slot />

    <!-- ── i18n Engine ──────────────────────────────────── -->
    <script is:inline>
      /* ── Theme Engine ─────────────────────────────────── */
      function __updateThemeIcon(isDark) {
        var icon = document.getElementById('theme-icon');
        if (!icon) return;
        icon.className = isDark
          ? 'fa-solid fa-sun text-base transition-transform duration-300'
          : 'fa-solid fa-moon text-base transition-transform duration-300';
      }

      function initTheme() {
        var isDark = document.documentElement.classList.contains('dark');
        __updateThemeIcon(isDark);
        var btn = document.getElementById('theme-toggle');
        if (btn && !btn.__themeInit) {
          btn.__themeInit = true;
          btn.addEventListener('click', function() {
            var nowDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', nowDark ? 'dark' : 'light');
            __updateThemeIcon(nowDark);
          });
        }
      }

      document.addEventListener('astro:page-load', initTheme);
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initTheme);
      } else {
        initTheme();
      }

      window.__i18n = {
        en: {
          /* Hero */
          'hero.description': 'Computer Science Engineer with over 7 years of experience building scalable, well-tested applications. Versatile profile combining modern backend and frontend solutions, quality assurance practices, infrastructure administration, and collaborations with international organizations like the UN (FAO).',
          'hero.cta.cv': 'Download CV',
          'hero.cta.contact': 'Contact',

          /* Skills */
          'skills.title': 'Technical Skills',
          'skills.title.1': 'Technical',
          'skills.title.2': 'Skills',
          'skills.subtitle': 'Tools and technologies I work with daily.',
          'skills.cat.0': 'Backend',
          'skills.cat.1': 'Frontend',
          'skills.cat.2': 'QA & Testing',
          'skills.cat.3': 'Databases',
          'skills.cat.4': 'DevOps & Control',
          'skills.cat.5': 'Infrastructure',
          'skills.cat.6': 'GIS & Data',
          'skills.cat.7': 'Applied AI',

          /* Experience */
          'exp.title': 'Professional Experience',
          'exp.title.1': 'Professional',
          'exp.title.2': 'Experience',
          'exp.subtitle': 'My career journey and academic background over the years.',
          'exp.0.title': 'Full Stack Developer & QA Engineer',
          'exp.0.date': '2023 – Present',
          'exp.0.desc': 'Development of agricultural platforms (prices, productivity, fertilizers), GIS systems with polygon visualization (Leaflet + GeoServer), mobile app for offline field data capture, and process automation bots. QA: end-to-end test case design, functional and regression testing before each release, API validation with Postman, and full bug lifecycle management.',
          'exp.1.title': 'Technology Consultant · Full Stack Developer / QA',
          'exp.1.desc': "Led development of Cuba's national Greenhouse Gas Inventory (INGEI) platform with automatic calculations and PDF/Excel reporting. Built the Agriculture & AFOLU sectoral system and the SICCA climate change platform with an AI module for recommendations. QA: rigorous validation of critical calculations reported to the UN, integration tests, and UAT coordination with MINAG and CITMA experts.",
          'exp.2.title': 'IT Specialist / Support & Internal QA',
          'exp.2.company': 'IAGRIC — Agricultural Engineering Institute',
          'exp.2.desc': 'Administered complete LAN/WAN infrastructure (routers, switches, servers) ensuring high availability. Implemented Active Directory with per-department group policies, automated backup and disaster recovery strategies, and advanced technical support. QA: acceptance testing of internal systems before institutional deployment.',
          'exp.3.title': 'Software Developer / QA',
          'exp.3.desc': 'Design, development and maintenance of web applications for security services management. QA: functional and regression testing each iteration, cross-browser compatibility verification, business rule validation, and structured bug reporting through to closure.',
          'exp.4.title': 'Computer Science Engineer',
          'exp.4.company': 'University of Computer Sciences (UCI) — La Habana',
          'exp.4.date': 'Graduate',
          'exp.4.desc': 'Academic training as a computer engineer, foundations in data structures, programming and algorithmic sciences.',

          /* Projects */
          'proj.0.title': 'Agroproductivity Platform',
          'proj.0.desc': 'Comprehensive agricultural suite covering soil agroproductivity analysis, polygon drawing and spatial data extraction, meteorological and hydrological reporting, agrochemical laboratory sample testing, and an interactive GeoServer-powered map with multi-category spatial layers.',
          'proj.1.title': 'SICCA (UN - FAO)',
          'proj.1.desc': "Platform for showcasing and disseminating climate change information, featuring a sector-based adaptation actions registry module and an AI-powered tool for monitoring and evaluating results.",
          'proj.2.title': 'INGEI Platform',
          'proj.2.desc': "Cuba's official National Greenhouse Gas Inventory (INGEI) — the instrument through which the country reports its emissions and absorptions to the United Nations Framework Convention on Climate Change (UNFCCC). Visual platform that processes dynamic formulas, analyzes historical series and automatically generates PDF and Excel reports.",
          'proj.3.title': 'Guajapp App & Bots',
          'proj.3.desc': 'Agricultural social network (Guajapp) connecting farming cooperatives through conversational bots — enabling procedure management, contract filing, GPS-based polygon drawing, satellite imagery consultation, and access to crop plans and agricultural data. Built on Matrix protocol with a Django REST backend.',
          'proj.4.title': 'PolyMap',
          'proj.4.desc': 'Geographic data visualization platform with interactive polygon drawing tools, real-time area calculation and field mapping for agricultural land management.',
          'proj.5.title': 'RCF Platform',
          'proj.5.desc': 'Flutter mobile app for tracking fertilizer registration procedures in Cuba, covering the full regulatory lifecycle — document submission, agreement signing, payment confirmation, technical review (dictamen), and official certification issuance. Backed by a Django REST API with multi-role access for requesting companies and regulatory administrators.',
          'proj.6.title': 'Network & Services Registration',
          'proj.6.desc': 'Corporate system for network device onboarding and service management with full Active Directory integration, automated report generation and centralized SQL Server database.',
          'proj.7.title': 'Agricultural Machinery Management',
          'proj.7.desc': 'Comprehensive inventory and maintenance management system for agricultural machinery fleets, including service scheduling, failure tracking and full maintenance history per unit.',
          'proj.8.title': 'Written Legacy Turf',
          'proj.8.desc': 'Premium artificial turf installation landing page for a Florida-based company. Features bilingual support (EN/ES), interactive before/after slider, service area map and WhatsApp integration.',
          'proj.9.title': 'GVoltsCorp',
          'proj.9.desc': 'Corporate landing page for a Florida security and electrical systems company. Showcases NICET III, OSHA and state certifications, brand partners (Honeywell, Hikvision) and service offerings.',
          'proj.cta.demo': 'View Demo',

          /* Footer */
          'footer.tagline': 'Full Stack Developer with over 7 years of experience building scalable and modern applications.',
          'footer.nav.title': 'Navigation',
          'footer.contact.title': 'Contact',
          'footer.nav.home': 'Home',
          'footer.nav.skills': 'Skills',
          'footer.nav.experience': 'Experience',
          'footer.nav.projects': 'Projects',
          'footer.nav.contact': 'Contact',
          'footer.copyright.rights': 'All rights reserved.',
          'footer.madewith': 'Made with',
          'footer.using': 'using',
        },
        es: {
          /* Hero */
          'hero.description': 'Ingeniero en Ciencias Informáticas con más de 7 años de experiencia construyendo aplicaciones escalables y bien testeadas. Perfil versátil combinando soluciones backend y frontend modernas, prácticas de aseguramiento de calidad, administración de infraestructura y colaboraciones con organismos internacionales como la ONU (FAO).',
          'hero.cta.cv': 'Descargar CV',
          'hero.cta.contact': 'Contactar',

          /* Skills */
          'skills.title': 'Habilidades Técnicas',
          'skills.title.1': 'Habilidades',
          'skills.title.2': 'Técnicas',
          'skills.subtitle': 'Herramientas y tecnologías con las que trabajo a diario.',
          'skills.cat.0': 'Backend',
          'skills.cat.1': 'Frontend',
          'skills.cat.2': 'QA & Testing',
          'skills.cat.3': 'Bases de Datos',
          'skills.cat.4': 'DevOps & Control',
          'skills.cat.5': 'Infraestructura',
          'skills.cat.6': 'GIS & Datos',
          'skills.cat.7': 'IA Aplicada',

          /* Experience */
          'exp.title': 'Experiencia Profesional',
          'exp.title.1': 'Experiencia',
          'exp.title.2': 'Profesional',
          'exp.subtitle': 'Mi trayectoria y formación académica a lo largo de los años.',
          'exp.0.title': 'Desarrollador Full Stack & QA Engineer',
          'exp.0.date': '2023 – Presente',
          'exp.0.desc': 'Desarrollo de plataformas agrícolas (precios, agroproductividad, fertilizantes), sistemas GIS con visualización de polígonos (Leaflet + GeoServer), app móvil para captura de datos en campo con sincronización offline y bots de automatización de procesos. QA: diseño y ejecución de casos de prueba end-to-end, pruebas funcionales y de regresión antes de cada release, validación de APIs con Postman y gestión completa del ciclo de vida de bugs.',
          'exp.1.title': 'Consultor de Tecnología · Full Stack Developer / QA',
          'exp.1.desc': 'Lideré el desarrollo de la plataforma nacional de Inventario de Gases de Efecto Invernadero (INGEI) de Cuba con cálculo automático y generación de reportes en PDF/Excel. Construí el sistema sectorial de Agricultura y AFOLU y la plataforma SICCA con módulo de IA para recomendaciones. QA: validación rigurosa de cálculos críticos reportados a la ONU, pruebas de integración y coordinación de UAT con expertos del MINAG y CITMA.',
          'exp.2.title': 'Especialista en TI / Soporte y QA Interno',
          'exp.2.company': 'IAGRIC — Instituto de Ingeniería Agrícola',
          'exp.2.desc': 'Administré infraestructura completa LAN/WAN (routers, switches, servidores) garantizando alta disponibilidad. Implementé Active Directory con políticas de grupo por departamento, estrategias de backup automatizado y recuperación ante desastres, y soporte técnico avanzado. QA: pruebas de aceptación de sistemas internos antes de su despliegue institucional.',
          'exp.3.title': 'Desarrollador de Software / QA',
          'exp.3.desc': 'Diseño, desarrollo y mantenimiento de aplicaciones web para la gestión de servicios de seguridad. QA: pruebas funcionales y de regresión en cada iteración, verificación de compatibilidad entre navegadores, validación de reglas de negocio y reporte estructurado de bugs hasta su cierre.',
          'exp.4.title': 'Ing. en Ciencias Informáticas',
          'exp.4.company': 'Universidad de las Ciencias Informáticas (UCI) — La Habana',
          'exp.4.date': 'Graduado',
          'exp.4.desc': 'Formación académica como ingeniero informático, bases en estructuras de datos, programación y ciencias algorítmicas.',

          /* Projects */
          'proj.0.title': 'Plataforma Agroproductividad',
          'proj.0.desc': 'Suite agrícola integral que abarca análisis de agroproductividad del suelo, trazado de polígonos y extracción de datos espaciales, reportes meteorológicos e hidrológicos, laboratorio agroquímico para registro de pruebas en muestras y un mapa interactivo con capas multicategoría impulsado por GeoServer.',
          'proj.1.title': 'SICCA (ONU - FAO)',
          'proj.1.desc': 'Plataforma para mostrar y divulgar información sobre cambio climático, con módulo de registro de acciones de adaptación por sectores y herramienta impulsada con Inteligencia Artificial para el monitoreo y evaluación de los resultados.',
          'proj.2.title': 'INGEI Platform',
          'proj.2.desc': 'Registro oficial del Inventario Nacional de Gases de Efecto Invernadero (INGEI) mediante el cual Cuba reporta sus emisiones y absorciones ante la Convención Marco de las Naciones Unidas sobre el Cambio Climático (CMNUCC). Plataforma visual que procesa fórmulas dinámicas, analiza series históricas y genera reportes automáticos en PDF y Excel.',
          'proj.3.title': 'Guajapp App & Bots',
          'proj.3.desc': 'Red social agrícola (Guajapp) que conecta cooperativas agropecuarias mediante bots conversacionales — gestión de trámites, contratos, trazado de polígonos por GPS, consulta de imágenes satelitales y acceso a planes de siembra y datos agrícolas. Construido sobre el protocolo Matrix con backend Django REST.',
          'proj.4.title': 'PolyMap',
          'proj.4.desc': 'Plataforma de visualización de datos geográficos con herramientas interactivas para el trazado de polígonos, cálculo de áreas en tiempo real y mapeo de parcelas para la gestión de terrenos agrícolas.',
          'proj.5.title': 'RCF Platform',
          'proj.5.desc': 'Aplicación móvil Flutter para el seguimiento de trámites de registro de fertilizantes en Cuba, cubriendo el ciclo regulatorio completo — presentación de documentos, firma de convenio, confirmación de pago, revisión técnica (dictamen) y emisión de certificación oficial. Respaldada por una API Django REST con acceso multirol para empresas solicitantes y administradores regulatorios.',
          'proj.6.title': 'Registro de Red y Servicios',
          'proj.6.desc': 'Sistema corporativo para el alta de dispositivos de red y gestión de servicios con integración completa de Active Directory, generación automatizada de reportes y base de datos centralizada en SQL Server.',
          'proj.7.title': 'Gestión de Maquinaria Agrícola',
          'proj.7.desc': 'Sistema integral de gestión de inventario y mantenimiento para flotas de maquinaria agrícola, con programación de servicios, seguimiento de averías e historial completo de mantenimiento por unidad.',
          'proj.8.title': 'Written Legacy Turf',
          'proj.8.desc': 'Landing page de instalación de césped artificial premium para una empresa de Florida. Incluye soporte bilingüe (EN/ES), slider interactivo antes/después, mapa de área de servicio e integración con WhatsApp.',
          'proj.9.title': 'GVoltsCorp',
          'proj.9.desc': 'Landing page corporativa para una empresa de sistemas de seguridad y electricidad en Florida. Muestra certificaciones NICET III, OSHA y estatales, socios de marca (Honeywell, Hikvision) y servicios.',
          'proj.cta.demo': 'Visitar',

          /* Footer */
          'footer.tagline': 'Desarrollador Full Stack con más de 7 años de experiencia construyendo aplicaciones escalables y modernas.',
          'footer.nav.title': 'Navegación',
          'footer.contact.title': 'Contacto',
          'footer.nav.home': 'Inicio',
          'footer.nav.skills': 'Habilidades',
          'footer.nav.experience': 'Experiencia',
          'footer.nav.projects': 'Proyectos',
          'footer.nav.contact': 'Contacto',
          'footer.copyright.rights': 'Todos los derechos reservados.',
          'footer.madewith': 'Hecho con',
          'footer.using': 'usando',
        }
      };

      function applyTranslations(lang) {
        var t = window.__i18n[lang];
        if (!t) return;

        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var key = el.getAttribute('data-i18n');
          if (t[key] !== undefined) el.textContent = t[key];
        });

        document.documentElement.lang = lang;
        localStorage.setItem('lang', lang);
        window.__currentLang = lang;

        var label = document.getElementById('lang-label');
        if (label) label.textContent = lang.toUpperCase();
      }

      window.__applyTranslations = applyTranslations;

      function initI18n() {
        var saved = localStorage.getItem('lang') || 'en';
        applyTranslations(saved);

        var btn = document.getElementById('lang-toggle');
        if (btn && !btn.__langInit) {
          btn.__langInit = true;
          btn.addEventListener('click', function() {
            var next = (window.__currentLang === 'en') ? 'es' : 'en';
            applyTranslations(next);
          });
        }
      }

      document.addEventListener('astro:page-load', initI18n);

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initI18n);
      } else {
        initI18n();
      }
    </script>

  </body>
</html>

<style>
  html, body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
