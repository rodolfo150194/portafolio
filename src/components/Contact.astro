---
---

<section id="contacto" class="relative bg-slate-50 dark:bg-[#030712] overflow-hidden">

    <!-- Decorative top border -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent pointer-events-none"></div>

    <!-- Background glows -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-cyan-500/[0.04] rounded-full blur-[140px]"></div>
        <div class="absolute bottom-1/4 right-1/5 w-[400px] h-[400px] bg-violet-600/[0.04] rounded-full blur-[120px]"></div>
        <div class="absolute inset-0"
             style="background-image: radial-gradient(circle, rgba(255,255,255,0.022) 1px, transparent 1px); background-size: 28px 28px;"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 py-28 text-center">

        <!-- Section label -->
        <div class="[font-family:'Space_Mono',monospace] text-[0.65rem] tracking-[0.18em] inline-flex items-center gap-[0.3rem] mb-5">
            <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">[</span>
            <span class="text-[rgba(34,211,238,0.85)]">contact.log</span>
            <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">]</span>
        </div>

        <!-- Heading -->
        <h2 class="[font-family:'Barlow_Condensed',sans-serif] font-black text-[clamp(3rem,10vw,6.5rem)] uppercase [letter-spacing:-0.01em] [line-height:0.95] text-gray-900 dark:text-white mb-6">
            <span class="block text-transparent" style="-webkit-text-stroke: 1px #2d3748;">Let's</span>
            <span class="text-[#22d3ee] italic">work</span> together
        </h2>

        <!-- Description -->
        <p class="[font-family:'Space_Mono',monospace] text-[0.72rem] text-[rgba(100,116,139,0.85)] leading-[1.8] tracking-[0.02em] max-w-[480px] mx-auto mb-10">
            Whether you have a project in mind, want to discuss a role, or just want to connect — I'd love to hear from you. I typically respond within 24 hours.
        </p>

        <!-- Availability badge -->
        <div class="inline-flex items-center gap-3 px-4 py-2.5 rounded-xl bg-emerald-500/10 border border-emerald-500/20 mb-10">
            <span class="relative flex w-2.5 h-2.5 flex-shrink-0">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
            </span>
            <span class="text-emerald-400 text-sm font-semibold tracking-wide">Open to opportunities</span>
        </div>

        <!-- CTA email button -->
        <div class="mb-14">
            <a href="mailto:rodygm0104@gmail.com"
               class="group inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-[#22d3ee] text-slate-900 text-base font-bold shadow-lg shadow-cyan-500/20 hover:shadow-xl hover:shadow-cyan-500/40 hover:-translate-y-0.5 transition-all duration-300">
                <i class="fa-solid fa-envelope text-lg"></i>
                <span>rodygm0104@gmail.com</span>
                <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform text-sm"></i>
            </a>
        </div>

        <!-- Social links -->
        <div class="flex items-center justify-center gap-4 flex-wrap mb-10">
            <a href="https://www.linkedin.com/in/rodolfo-garcia-dev/" target="_blank" rel="noopener noreferrer"
               class="group flex items-center gap-3 px-5 py-3 rounded-xl bg-gray-100 dark:bg-white/[0.025] border border-gray-200 dark:border-white/[0.07] hover:border-[#0a66c2]/30 hover:bg-[#0a66c2]/[0.06] transition-all duration-300">
                <div class="w-8 h-8 flex items-center justify-center rounded-lg bg-[#0a66c2]/10 text-[#0a66c2] group-hover:bg-[#0a66c2] group-hover:text-white transition-all duration-300">
                    <i class="fa-brands fa-linkedin-in text-sm"></i>
                </div>
                <span class="text-gray-700 dark:text-slate-300 text-sm group-hover:text-white transition-colors">LinkedIn</span>
            </a>

            <a href="https://github.com/rodolfo150194" target="_blank" rel="noopener noreferrer"
               class="group flex items-center gap-3 px-5 py-3 rounded-xl bg-gray-100 dark:bg-white/[0.025] border border-gray-200 dark:border-white/[0.07] hover:border-gray-300 dark:hover:border-white/20 hover:bg-gray-200 dark:hover:bg-white/[0.04] transition-all duration-300">
                <div class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-200 dark:bg-white/5 text-slate-500 dark:text-slate-400 group-hover:bg-gray-300 dark:group-hover:bg-white/15 group-hover:text-gray-900 dark:group-hover:text-white transition-all duration-300">
                    <i class="fa-brands fa-github text-sm"></i>
                </div>
                <span class="text-gray-700 dark:text-slate-300 text-sm group-hover:text-gray-900 dark:group-hover:text-white transition-colors">GitHub</span>
            </a>
        </div>

        <!-- CV Download -->
        <a href="/assets/documents/CV_Rodolfo_Garcia.pdf" target="_blank"
           class="group inline-flex items-center gap-2.5 px-5 py-3 rounded-lg border border-gray-200 dark:border-white/10 text-slate-500 hover:text-[#22d3ee] hover:border-[#22d3ee]/30 text-sm font-medium transition-all duration-300">
            <i class="fa-solid fa-file-pdf text-red-400/60 group-hover:text-red-400 transition-colors text-base"></i>
            Download CV (PDF)
            <i class="fa-solid fa-arrow-down text-[10px] group-hover:translate-y-0.5 transition-transform"></i>
        </a>

    </div>
</section>
