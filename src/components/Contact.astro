---
---

<section id="contacto" class="relative bg-[#030712] overflow-hidden">

    <!-- Decorative top border -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent pointer-events-none"></div>

    <!-- Background glows -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-cyan-500/[0.04] rounded-full blur-[140px]"></div>
        <div class="absolute bottom-1/4 right-1/5 w-[400px] h-[400px] bg-violet-600/[0.04] rounded-full blur-[120px]"></div>
        <!-- Dot grid -->
        <div class="absolute inset-0 opacity-100"
             style="background-image: radial-gradient(circle, rgba(255,255,255,0.022) 1px, transparent 1px); background-size: 28px 28px;"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 py-28">

        <!-- Section header -->
        <div class="mb-20">
            <div class="flex items-center gap-3 mb-5">
                <span class="font-mono text-[0.72rem] text-slate-600 tracking-[0.14em]">// get in touch</span>
                <div class="h-px w-20 bg-gradient-to-r from-slate-800 to-transparent"></div>
            </div>
            <h2 class="font-display text-[clamp(3.5rem,10vw,7rem)] font-extrabold text-white leading-[0.9] tracking-tight">
                <span class="block text-transparent" style="-webkit-text-stroke: 1px #2d3748;">Let's</span>
                <span class="text-primary">work</span> together
            </h2>
        </div>

        <!-- Two-column layout -->
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-14 lg:gap-20 items-start">

            <!-- Left: Info column -->
            <div class="lg:col-span-2 flex flex-col gap-8">

                <!-- Availability badge -->
                <div class="inline-flex items-center gap-3 px-4 py-2.5 rounded-xl bg-emerald-500/10 border border-emerald-500/20 w-fit">
                    <span class="relative flex w-2.5 h-2.5 flex-shrink-0">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                    </span>
                    <span class="text-emerald-400 text-sm font-semibold tracking-wide">Open to opportunities</span>
                </div>

                <!-- Description -->
                <p class="text-slate-400 text-[0.95rem] leading-[1.85]">
                    Whether you have a project in mind, want to discuss a role, or just want to connect — I'd love to hear from you. I typically respond within 24 hours.
                </p>

                <!-- Contact details -->
                <div class="flex flex-col gap-3">
                    <a href="mailto:rodygm0104@gmail.com"
                       class="group flex items-center gap-4 p-4 rounded-xl bg-white/[0.025] border border-white/[0.07] hover:border-primary/25 hover:bg-primary/[0.04] transition-all duration-300">
                        <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-lg bg-primary/10 text-primary group-hover:bg-primary group-hover:text-slate-900 transition-all duration-300">
                            <i class="fa-solid fa-envelope text-sm"></i>
                        </div>
                        <div>
                            <p class="text-[10px] text-slate-600 font-semibold uppercase tracking-[0.18em] mb-0.5">Email</p>
                            <p class="text-slate-300 text-sm group-hover:text-white transition-colors">rodygm0104@gmail.com</p>
                        </div>
                    </a>

                    <a href="https://www.linkedin.com/in/rodolfo-garcia-dev/" target="_blank" rel="noopener noreferrer"
                       class="group flex items-center gap-4 p-4 rounded-xl bg-white/[0.025] border border-white/[0.07] hover:border-[#0a66c2]/30 hover:bg-[#0a66c2]/[0.04] transition-all duration-300">
                        <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-lg bg-[#0a66c2]/10 text-[#0a66c2] group-hover:bg-[#0a66c2] group-hover:text-white transition-all duration-300">
                            <i class="fa-brands fa-linkedin-in text-sm"></i>
                        </div>
                        <div>
                            <p class="text-[10px] text-slate-600 font-semibold uppercase tracking-[0.18em] mb-0.5">LinkedIn</p>
                            <p class="text-slate-300 text-sm group-hover:text-white transition-colors">linkedin.com/in/rodolfo-garcia-dev</p>
                        </div>
                    </a>

                    <a href="https://github.com/rodolfo150194" target="_blank" rel="noopener noreferrer"
                       class="group flex items-center gap-4 p-4 rounded-xl bg-white/[0.025] border border-white/[0.07] hover:border-white/20 hover:bg-white/[0.04] transition-all duration-300">
                        <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-lg bg-white/5 text-slate-400 group-hover:bg-white/15 group-hover:text-white transition-all duration-300">
                            <i class="fa-brands fa-github text-sm"></i>
                        </div>
                        <div>
                            <p class="text-[10px] text-slate-600 font-semibold uppercase tracking-[0.18em] mb-0.5">GitHub</p>
                            <p class="text-slate-300 text-sm group-hover:text-white transition-colors">github.com/rodolfo150194</p>
                        </div>
                    </a>
                </div>

                <!-- CV Download -->
                <div class="pt-1">
                    <a href="/assets/documents/CV_Rodolfo_Garcia.pdf" target="_blank"
                       class="group inline-flex items-center gap-2.5 px-5 py-3 rounded-lg border border-white/10 text-slate-500 hover:text-primary hover:border-primary/30 text-sm font-medium transition-all duration-300">
                        <i class="fa-solid fa-file-pdf text-red-400/60 group-hover:text-red-400 transition-colors text-base"></i>
                        Download CV (PDF)
                        <i class="fa-solid fa-arrow-down text-[10px] group-hover:translate-y-0.5 transition-transform"></i>
                    </a>
                </div>
            </div>

            <!-- Right: Form column -->
            <div class="lg:col-span-3">

                <!-- Form -->
                <form id="contact-form" class="flex flex-col gap-5" novalidate>

                    <!-- Name + Email -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div class="flex flex-col gap-2">
                            <label for="cf-name" class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.18em]">Name</label>
                            <input
                                id="cf-name"
                                name="name"
                                type="text"
                                placeholder="Your full name"
                                required
                                class="w-full px-4 py-3 rounded-lg bg-white/[0.04] border border-white/[0.09] text-white placeholder:text-slate-700 text-sm focus:outline-none focus:border-primary/40 focus:bg-primary/[0.04] transition-all duration-300"
                            />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label for="cf-email" class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.18em]">Email</label>
                            <input
                                id="cf-email"
                                name="email"
                                type="email"
                                placeholder="your@email.com"
                                required
                                class="w-full px-4 py-3 rounded-lg bg-white/[0.04] border border-white/[0.09] text-white placeholder:text-slate-700 text-sm focus:outline-none focus:border-primary/40 focus:bg-primary/[0.04] transition-all duration-300"
                            />
                        </div>
                    </div>

                    <!-- Subject -->
                    <div class="flex flex-col gap-2">
                        <label for="cf-subject" class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.18em]">Subject</label>
                        <input
                            id="cf-subject"
                            name="subject"
                            type="text"
                            placeholder="Job opportunity / Project / Collaboration..."
                            class="w-full px-4 py-3 rounded-lg bg-white/[0.04] border border-white/[0.09] text-white placeholder:text-slate-700 text-sm focus:outline-none focus:border-primary/40 focus:bg-primary/[0.04] transition-all duration-300"
                        />
                    </div>

                    <!-- Message -->
                    <div class="flex flex-col gap-2">
                        <label for="cf-message" class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.18em]">Message</label>
                        <textarea
                            id="cf-message"
                            name="message"
                            rows="6"
                            placeholder="Tell me about your project, the role, or just say hi..."
                            required
                            class="w-full px-4 py-3 rounded-lg bg-white/[0.04] border border-white/[0.09] text-white placeholder:text-slate-700 text-sm focus:outline-none focus:border-primary/40 focus:bg-primary/[0.04] transition-all duration-300 resize-none"
                        ></textarea>
                    </div>

                    <!-- Submit row -->
                    <div class="flex items-center gap-4 flex-wrap pt-1">
                        <button
                            type="submit"
                            class="group inline-flex items-center gap-2.5 px-7 py-3.5 rounded-lg bg-primary text-slate-900 text-sm font-bold shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/35 hover:-translate-y-0.5 transition-all duration-300"
                        >
                            <span>Send Message</span>
                            <i class="fa-solid fa-paper-plane group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"></i>
                        </button>
                        <p class="text-[11px] text-slate-600">Opens your email client — no data is stored.</p>
                    </div>
                </form>

                <!-- Success state -->
                <div id="contact-success" class="hidden flex-col items-center justify-center py-20 text-center">
                    <div class="w-16 h-16 rounded-full bg-emerald-500/15 border border-emerald-500/30 flex items-center justify-center mb-6 mx-auto">
                        <i class="fa-solid fa-check text-emerald-400 text-2xl"></i>
                    </div>
                    <h3 class="font-display text-2xl font-extrabold text-white mb-2">Email client opened!</h3>
                    <p class="text-slate-400 text-sm max-w-xs mx-auto">Your message draft is ready to send. Looking forward to connecting with you.</p>
                    <button
                        id="cf-reset"
                        class="mt-8 text-xs text-slate-600 hover:text-primary transition-colors underline underline-offset-4"
                    >
                        Send another message
                    </button>
                </div>

            </div>
        </div>
    </div>
</section>

<script is:inline>
(function () {
    function initContact() {
        var form    = document.getElementById('contact-form');
        var success = document.getElementById('contact-success');
        var reset   = document.getElementById('cf-reset');
        if (!form || form.__contactInit) return;
        form.__contactInit = true;

        form.addEventListener('submit', function (e) {
            e.preventDefault();
            var name    = document.getElementById('cf-name').value.trim();
            var email   = document.getElementById('cf-email').value.trim();
            var subject = document.getElementById('cf-subject').value.trim() || 'Portfolio Contact';
            var message = document.getElementById('cf-message').value.trim();
            if (!name || !email || !message) return;

            var body   = 'Name: ' + name + '\nEmail: ' + email + '\n\n' + message;
            var mailto = 'mailto:rodygm0104@gmail.com?subject=' +
                         encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
            window.open(mailto, '_blank');

            form.classList.add('hidden');
            success.classList.remove('hidden');
            success.classList.add('flex');
        });

        if (reset) {
            reset.addEventListener('click', function () {
                success.classList.add('hidden');
                success.classList.remove('flex');
                form.classList.remove('hidden');
                form.reset();
            });
        }
    }

    document.addEventListener('astro:page-load', initContact);
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initContact);
    } else {
        initContact();
    }
})();
</script>
