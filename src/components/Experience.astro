---
const experiences = [
    {
        title: "Desarrollador Web Full Stack",
        company: "Freelance — Code43w",
        date: "2021 – Presente",
        description: "Desarrollo de plataformas agrícolas, microlocalizaciones, APIs REST y bots para trámites utilizando ecosistemas de Python, Django, Leaflet y aplicaciones móviles.",
        icon: "fa-solid fa-briefcase"
    },
    {
        title: "Consultor de Tecnología",
        company: "FAO — ONU",
        date: "2022 – 2023",
        description: "Desarrollo del portal INGEI y la plataforma SICCA con inteligencia artificial para la generación de reportes climáticos, uso de Wagtail, Django y herramientas de visualización interactivas.",
        icon: "fa-solid fa-globe"
    },
    {
        title: "Especialista en TI",
        company: "IAGRIC — Instituto de Ingeniería Agrícola",
        date: "2020 – 2023",
        description: "Administración de redes LAN/WAN, gestión de Active Directory, políticas de seguridad, backups y soporte técnico avanzado corporativo.",
        icon: "fa-solid fa-server"
    },
    {
        title: "Desarrollador de Software",
        company: "SEISA",
        date: "2018 – 2020",
        description: "Diseño, estructuración y desarrollo de aplicaciones web para la gestión integral de servicios de seguridad.",
        icon: "fa-solid fa-code"
    },
    {
        title: "Ing. en Ciencias Informáticas",
        company: "Universidad de las Ciencias Informáticas (UCI)",
        date: "Graduado",
        description: "Formación académica como ingeniero informático, bases en estructuras de datos, programación y ciencias algorítmicas.",
        icon: "fa-solid fa-graduation-cap"
    }
];
---

<section id="experiencia" class="relative py-24 bg-gray-950 overflow-hidden">
    <!-- Fondo decorativo -->
    <div class="absolute inset-0 z-0 opacity-10 pointer-events-none">
        <div class="absolute top-1/4 -left-32 w-96 h-96 bg-primary rounded-full blur-[120px]"></div>
        <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-blue-500 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-4xl mx-auto px-4 relative z-10">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Experiencia Profesional</h2>
            <p class="text-xl text-slate-400">Mi trayectoria y formación académica a lo largo de los años.</p>
        </div>

        <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-white/20 before:to-transparent">
            {experiences.map((exp, index) => (
                <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
                    <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white/20 bg-gray-900 shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 text-primary z-10 transition-transform duration-300 group-hover:scale-110">
                        <i class={`${exp.icon} text-lg`}></i>
                    </div>
                    
                    <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-6 bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl shadow-xl transition-all duration-300 hover:bg-white/10 hover:-translate-y-1 hover:shadow-primary/10 hover:border-primary/30">
                        <div class="flex flex-col md:flex-row md:items-center justify-between mb-2 gap-2">
                            <h3 class="font-bold text-white text-xl">{exp.title}</h3>
                            <time class="font-mono text-sm text-primary bg-primary/10 px-3 py-1 rounded-full w-fit whitespace-nowrap">{exp.date}</time>
                        </div>
                        <div class="text-slate-300 font-medium mb-3">{exp.company}</div>
                        <p class="text-slate-400 leading-relaxed text-sm md:text-base">
                            {exp.description}
                        </p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
