---
const experiences = [
    {
        i18nTitle: "exp.0.title",
        title: "Full Stack Developer & QA Engineer",
        company: "Freelance — Code43w",
        i18nDate: "exp.0.date",
        date: "2023 – Present",
        i18nDesc: "exp.0.desc",
        description: "Development of agricultural platforms (prices, productivity, fertilizers), GIS systems with polygon visualization (Leaflet + GeoServer), mobile app for offline field data capture, and process automation bots. QA: end-to-end test case design, functional and regression testing before each release, API validation with Postman, and full bug lifecycle management.",
        icon: "fa-solid fa-briefcase"
    },
    {
        i18nTitle: "exp.1.title",
        title: "Technology Consultant · Full Stack Developer / QA",
        company: "FAO — United Nations",
        date: "2022 – 2023",
        i18nDesc: "exp.1.desc",
        description: "Led development of Cuba's national Greenhouse Gas Inventory (INGEI) platform with automatic calculations and PDF/Excel reporting. Built the Agriculture & AFOLU sectoral system and the SICCA climate change platform with an AI module for recommendations. QA: rigorous validation of critical calculations reported to the UN, integration tests, and UAT coordination with MINAG and CITMA experts.",
        icon: "fa-solid fa-globe"
    },
    {
        i18nTitle: "exp.2.title",
        title: "IT Specialist / Support & Internal QA",
        i18nCompany: "exp.2.company",
        company: "IAGRIC — Agricultural Engineering Institute",
        date: "2020 – 2023",
        i18nDesc: "exp.2.desc",
        description: "Administered complete LAN/WAN infrastructure (routers, switches, servers) ensuring high availability. Implemented Active Directory with per-department group policies, automated backup and disaster recovery strategies, and advanced technical support. QA: acceptance testing of internal systems before institutional deployment, including functional, light load, and post-deploy verification.",
        icon: "fa-solid fa-server"
    },
    {
        i18nTitle: "exp.3.title",
        title: "Software Developer / QA",
        company: "SEISA — Servicios de Seguridad Integral",
        date: "2018 – 2020",
        i18nDesc: "exp.3.desc",
        description: "Design, development and maintenance of web applications for security services management. QA: functional and regression testing each iteration, cross-browser compatibility verification, business rule validation, and structured bug reporting through to closure.",
        icon: "fa-solid fa-code"
    },
    {
        i18nTitle: "exp.4.title",
        title: "Computer Science Engineer",
        i18nCompany: "exp.4.company",
        company: "University of Computer Sciences (UCI) — La Habana",
        i18nDate: "exp.4.date",
        date: "Graduate",
        i18nDesc: "exp.4.desc",
        description: "Academic training as a computer engineer, foundations in data structures, programming and algorithmic sciences.",
        icon: "fa-solid fa-graduation-cap"
    }
];

const clipLeft  = '[clip-path:polygon(0_0,calc(100%_-_14px)_0,100%_14px,100%_100%,14px_100%,0_calc(100%_-_14px))]';
const clipRight = '[clip-path:polygon(14px_0,100%_0,100%_calc(100%_-_14px),calc(100%_-_14px)_100%,0_100%,0_14px)]';
---

<section id="experiencia" class="relative py-28 bg-slate-50 dark:bg-[#030712] overflow-hidden">

    <!-- Blueprint dot grid -->
    <div
        class="absolute inset-0 pointer-events-none z-0 [background-image:radial-gradient(rgba(34,211,238,0.055)_1px,transparent_1px)] [background-size:24px_24px]"
        aria-hidden="true"
    ></div>

    <!-- Atmospheric glows -->
    <div class="absolute inset-0 pointer-events-none z-0" aria-hidden="true">
        <div class="absolute rounded-full blur-[110px] top-[-5%] left-[15%] w-[500px] h-[500px] [background:radial-gradient(circle,rgba(34,211,238,0.07),transparent_70%)]"></div>
        <div class="absolute rounded-full blur-[110px] bottom-[-5%] right-[15%] w-[380px] h-[380px] [background:radial-gradient(circle,rgba(34,211,238,0.07),transparent_70%)]"></div>
    </div>

    <div class="max-w-[62rem] mx-auto px-6 relative z-[1]">

        <!-- Header -->
        <header class="text-center mb-20">
            <div class="[font-family:'Space_Mono',monospace] text-[0.65rem] tracking-[0.18em] inline-flex items-center gap-[0.3rem] mb-5">
                <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">[</span>
                <span class="text-[rgba(34,211,238,0.85)]">career.log</span>
                <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">]</span>
            </div>
            <h2
                class="[font-family:'Barlow_Condensed',sans-serif] font-black text-[clamp(2.5rem,7vw,4.5rem)] max-sm:text-[clamp(2rem,9vw,3rem)] uppercase [letter-spacing:-0.01em] [line-height:0.95] text-gray-900 dark:text-white m-0 mb-5"
            >
                <span data-i18n="exp.title.1" style="color: transparent; -webkit-text-stroke: 2px #22d3ee;">Professional</span>
                <span data-i18n="exp.title.2" class="italic block">Experience</span>
            </h2>
            <p
                data-i18n="exp.subtitle"
                class="[font-family:'Space_Mono',monospace] text-[0.72rem] text-[rgba(100,116,139,0.85)] max-w-[360px] mx-auto leading-[1.8] tracking-[0.02em]"
            >
                My career journey and academic background over the years.
            </p>
        </header>

        <!-- Roadmap -->
        <div class="relative">
            {experiences.map((exp, index) => {
                const isLeft = index % 2 === 0;
                const isLast = index === experiences.length - 1;
                const num = (index + 1).toString().padStart(2, '0');

                return (
                    <div>
                        <!-- Item row -->
                        <div class="group relative flex items-start">

                            <!-- Node — LEFT side (even items) -->
                            {isLeft && (
                                <div class="relative z-10 flex-shrink-0 flex flex-col items-center pt-[0.65rem] mr-5 max-sm:mr-4">
                                    <div class="relative">
                                        <div class="absolute -inset-1 border border-[rgba(34,211,238,0.45)] rotate-45 animate-pulseDiamond pointer-events-none"></div>
                                        <div class="w-[46px] h-[46px] bg-white dark:bg-[#030712] border-[1.5px] border-[#22d3ee] rotate-45 flex items-center justify-center shadow-[0_0_18px_rgba(34,211,238,0.22),inset_0_0_14px_rgba(34,211,238,0.06)] transition-all duration-[350ms] relative z-[1] group-hover:shadow-[0_0_36px_rgba(34,211,238,0.5),inset_0_0_18px_rgba(34,211,238,0.14)] group-hover:border-[#a5f3fc]">
                                            <i class:list={[exp.icon, '-rotate-45 text-[#22d3ee] text-[0.9rem] transition-all duration-[350ms] group-hover:scale-[1.2] group-hover:text-white']}></i>
                                        </div>
                                    </div>
                                    <span class="[font-family:'Space_Mono',monospace] text-[0.5rem] text-[rgba(34,211,238,0.4)] mt-[6px] tracking-[0.08em]">{num}</span>
                                </div>
                            )}

                            <!-- Card -->
                            <article class:list={[
                                'relative flex-1 bg-[rgba(34,211,238,0.022)] border border-[rgba(34,211,238,0.1)] overflow-hidden drop-shadow-[0_2px_10px_rgba(0,0,0,0.55)] transition-[background,border-color,filter] duration-[350ms] group-hover:bg-[rgba(34,211,238,0.045)] group-hover:border-[rgba(34,211,238,0.22)] group-hover:drop-shadow-[0_0_22px_rgba(34,211,238,0.12)] max-sm:[clip-path:none]',
                                isLeft ? clipLeft : clipRight
                            ]}>

                                <!-- Top accent gradient line -->
                                <div class:list={[
                                    'h-[1.5px] w-full',
                                    isLeft
                                        ? 'bg-[linear-gradient(270deg,rgba(34,211,238,0)_0%,rgba(34,211,238,0.6)_50%,rgba(34,211,238,0.35)_100%)]'
                                        : 'bg-[linear-gradient(90deg,rgba(34,211,238,0)_0%,rgba(34,211,238,0.6)_50%,rgba(34,211,238,0.35)_100%)]'
                                ]}></div>

                                <!-- Compact header (always visible) -->
                                <div class="px-5 pt-4 pb-3">
                                    <div class="flex justify-between items-start gap-3 flex-wrap mb-[0.2rem]">
                                        <h3
                                            data-i18n={exp.i18nTitle}
                                            class="[font-family:'Barlow_Condensed',sans-serif] font-extrabold text-[1.2rem] uppercase tracking-[0.05em] text-gray-900 dark:text-white m-0 leading-[1.2]"
                                        >{exp.title}</h3>
                                        <time
                                            data-i18n={exp.i18nDate}
                                            class="[font-family:'Space_Mono',monospace] text-[0.68rem] text-[#22d3ee] bg-[rgba(34,211,238,0.07)] border border-[rgba(34,211,238,0.18)] py-[2px] px-2 whitespace-nowrap shrink-0 tracking-[0.06em]"
                                        >{exp.date}</time>
                                    </div>
                                    <p
                                        data-i18n={exp.i18nCompany}
                                        class="[font-family:'Space_Mono',monospace] text-[0.73rem] text-[rgba(100,116,139,0.85)] m-0 tracking-[0.02em]"
                                    >{exp.company}</p>

                                    <!-- Hover hint — hides when expanded -->
                                    <p class="[font-family:'Space_Mono',monospace] text-[0.5rem] text-[rgba(34,211,238,0.32)] mt-[0.4rem] tracking-[0.06em] flex items-center gap-[0.35rem] transition-opacity duration-300 group-hover:opacity-0 select-none" aria-hidden="true">
                                        <i class="fa-solid fa-chevron-down text-[0.42rem]"></i>
                                        <span>expand</span>
                                    </p>
                                </div>

                                <!-- Expandable description (grid-rows trick) -->
                                <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-[grid-template-rows] duration-500">
                                    <div class="overflow-hidden">
                                        <div class="px-5 pb-5 pt-0">
                                            <div class="h-px w-full bg-[rgba(34,211,238,0.1)] mb-[0.75rem]"></div>
                                            <p
                                                data-i18n={exp.i18nDesc}
                                                class="text-[0.88rem] text-[rgba(100,116,139,0.9)] leading-[1.75] m-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 [transition-delay:180ms]"
                                            >{exp.description}</p>
                                        </div>
                                    </div>
                                </div>
                            </article>

                            <!-- Node — RIGHT side (odd items) -->
                            {!isLeft && (
                                <div class="relative z-10 flex-shrink-0 flex flex-col items-center pt-[0.65rem] ml-5 max-sm:ml-0 max-sm:mr-4 max-sm:order-first">
                                    <div class="relative">
                                        <div class="absolute -inset-1 border border-[rgba(34,211,238,0.45)] rotate-45 animate-pulseDiamond pointer-events-none"></div>
                                        <div class="w-[46px] h-[46px] bg-white dark:bg-[#030712] border-[1.5px] border-[#22d3ee] rotate-45 flex items-center justify-center shadow-[0_0_18px_rgba(34,211,238,0.22),inset_0_0_14px_rgba(34,211,238,0.06)] transition-all duration-[350ms] relative z-[1] group-hover:shadow-[0_0_36px_rgba(34,211,238,0.5),inset_0_0_18px_rgba(34,211,238,0.14)] group-hover:border-[#a5f3fc]">
                                            <i class:list={[exp.icon, '-rotate-45 text-[#22d3ee] text-[0.9rem] transition-all duration-[350ms] group-hover:scale-[1.2] group-hover:text-white']}></i>
                                        </div>
                                    </div>
                                    <span class="[font-family:'Space_Mono',monospace] text-[0.5rem] text-[rgba(34,211,238,0.4)] mt-[6px] tracking-[0.08em]">{num}</span>
                                </div>
                            )}
                        </div>

                        <!-- Zigzag connector (not shown after last item) -->
                        {!isLast && (
                            <div class="relative h-14 pointer-events-none" aria-hidden="true">
                                <div class:list={[
                                    'absolute top-0 bottom-0 border-[rgba(34,211,238,0.22)]',
                                    isLeft
                                        /* even→odd: from left node (x=23px), curve right to meet right node (x=row−23px) */
                                        ? 'left-[23px] right-[23px] border-l border-b rounded-bl-[2.5rem] max-sm:right-0 max-sm:border-b-0 max-sm:rounded-none'
                                        /* odd→even: from right node (x=row−23px), curve left to meet left node (x=23px) */
                                        : 'left-[23px] right-[23px] border-r border-b rounded-br-[2.5rem] max-sm:left-[23px] max-sm:right-0 max-sm:border-r-0 max-sm:border-l max-sm:border-b-0 max-sm:rounded-none'
                                ]}></div>
                            </div>
                        )}
                    </div>
                );
            })}
        </div>

    </div>
</section>
