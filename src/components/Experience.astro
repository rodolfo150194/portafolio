---
const experiences = [
    {
        i18nTitle: "exp.0.title",
        title: "Full Stack Web Developer",
        company: "Freelance — Code43w",
        i18nDate: "exp.0.date",
        date: "2021 – Present",
        i18nDesc: "exp.0.desc",
        description: "Development of agricultural platforms, micro-localizations, REST APIs and bots for procedures using Python, Django, Leaflet ecosystems and mobile applications.",
        icon: "fa-solid fa-briefcase"
    },
    {
        i18nTitle: "exp.1.title",
        title: "Technology Consultant",
        company: "FAO — UN",
        date: "2022 – 2023",
        i18nDesc: "exp.1.desc",
        description: "Development of the INGEI portal and the SICCA platform with artificial intelligence for climate report generation, using Wagtail, Django and interactive visualization tools.",
        icon: "fa-solid fa-globe"
    },
    {
        i18nTitle: "exp.2.title",
        title: "IT Specialist",
        i18nCompany: "exp.2.company",
        company: "IAGRIC — Agricultural Engineering Institute",
        date: "2020 – 2023",
        i18nDesc: "exp.2.desc",
        description: "LAN/WAN network administration, Active Directory management, security policies, backups and advanced corporate technical support.",
        icon: "fa-solid fa-server"
    },
    {
        i18nTitle: "exp.3.title",
        title: "Software Developer",
        company: "SEISA",
        date: "2018 – 2020",
        i18nDesc: "exp.3.desc",
        description: "Design, structuring and development of web applications for the comprehensive management of security services.",
        icon: "fa-solid fa-code"
    },
    {
        i18nTitle: "exp.4.title",
        title: "Computer Science Engineer",
        i18nCompany: "exp.4.company",
        company: "University of Computer Sciences (UCI)",
        i18nDate: "exp.4.date",
        date: "Graduate",
        i18nDesc: "exp.4.desc",
        description: "Academic training as a computer engineer, foundations in data structures, programming and algorithmic sciences.",
        icon: "fa-solid fa-graduation-cap"
    }
];
---

<section id="experiencia" class="relative py-28 bg-[#030712] overflow-hidden">

    <!-- Blueprint dot grid -->
    <div
        class="absolute inset-0 pointer-events-none z-0 [background-image:radial-gradient(rgba(34,211,238,0.055)_1px,transparent_1px)] [background-size:24px_24px]"
        aria-hidden="true"
    ></div>

    <!-- Atmospheric glows -->
    <div class="absolute inset-0 pointer-events-none z-0" aria-hidden="true">
        <div class="absolute rounded-full blur-[110px] top-[-5%] left-[15%] w-[500px] h-[500px] [background:radial-gradient(circle,rgba(34,211,238,0.07),transparent_70%)]"></div>
        <div class="absolute rounded-full blur-[110px] bottom-[-5%] right-[15%] w-[380px] h-[380px] [background:radial-gradient(circle,rgba(34,211,238,0.07),transparent_70%)]"></div>
    </div>

    <div class="max-w-[58rem] mx-auto px-6 relative z-[1]">

        <!-- Header -->
        <header class="text-center mb-20">
            <div class="[font-family:'Space_Mono',monospace] text-[0.65rem] tracking-[0.18em] inline-flex items-center gap-[0.3rem] mb-5">
                <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">[</span>
                <span class="text-[rgba(34,211,238,0.85)]">career.log</span>
                <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">]</span>
            </div>
            <h2
                data-i18n="exp.title"
                class="[font-family:'Barlow_Condensed',sans-serif] font-black text-[clamp(2.5rem,7vw,4.5rem)] max-sm:text-[clamp(2rem,9vw,3rem)] uppercase [letter-spacing:-0.01em] [line-height:0.95] text-white m-0 mb-5"
            >
                Professional <span class="italic text-[#22d3ee] block">Experience</span>
            </h2>
            <p
                data-i18n="exp.subtitle"
                class="[font-family:'Space_Mono',monospace] text-[0.72rem] text-[rgba(100,116,139,0.85)] max-w-[360px] mx-auto leading-[1.8] tracking-[0.02em]"
            >
                My career journey and academic background over the years.
            </p>
        </header>

        <!-- Timeline -->
        <div class="relative flex flex-col before:content-[''] before:absolute before:left-1/2 before:top-0 before:bottom-0 before:w-px before:-translate-x-1/2 before:[background:linear-gradient(180deg,transparent_0%,rgba(34,211,238,0.3)_6%,rgba(34,211,238,0.3)_94%,transparent_100%)] before:z-0 max-sm:before:left-[27px] max-sm:before:translate-x-0">

            {experiences.map((exp, index) => {
                const isLeft = index % 2 === 0;
                const num = (index + 1).toString().padStart(2, '0');

                return (
                    <div class="group grid grid-cols-[1fr_80px_1fr] items-center relative pb-14 last:pb-0 max-sm:grid-cols-[54px_1fr]">

                        <!-- Card -->
                        <div class:list={[
                            'flex max-sm:col-start-2 max-sm:row-start-1 max-sm:justify-start max-sm:pl-[0.85rem] max-sm:pr-0',
                            isLeft
                                ? 'col-start-1 justify-end pr-7'
                                : 'col-start-3 justify-start pl-7'
                        ]}>
                            <article class:list={[
                                'bg-[rgba(34,211,238,0.022)] border border-[rgba(34,211,238,0.1)] overflow-hidden w-full transition-[background,filter,border-color] duration-[350ms] drop-shadow-[0_2px_10px_rgba(0,0,0,0.55)] group-hover:bg-[rgba(34,211,238,0.045)] group-hover:border-[rgba(34,211,238,0.22)] group-hover:drop-shadow-[0_0_20px_rgba(34,211,238,0.1)]',
                                isLeft
                                    ? '[clip-path:polygon(0_0,calc(100%_-_16px)_0,100%_16px,100%_100%,16px_100%,0_calc(100%_-_16px))]'
                                    : '[clip-path:polygon(16px_0,100%_0,100%_calc(100%_-_16px),calc(100%_-_16px)_100%,0_100%,0_16px)]'
                            ]}>
                                <div class:list={[
                                    'h-[1.5px] w-full',
                                    isLeft
                                        ? 'bg-[linear-gradient(270deg,rgba(34,211,238,0)_0%,rgba(34,211,238,0.6)_50%,rgba(34,211,238,0.35)_100%)]'
                                        : 'bg-[linear-gradient(90deg,rgba(34,211,238,0)_0%,rgba(34,211,238,0.6)_50%,rgba(34,211,238,0.35)_100%)]'
                                ]}></div>
                                <div class="px-5 pt-4 pb-[1.2rem]">
                                    <div class="flex justify-between items-start gap-3 flex-wrap mb-[0.35rem]">
                                        <h3
                                            data-i18n={exp.i18nTitle}
                                            class="[font-family:'Barlow_Condensed',sans-serif] font-extrabold text-[1.1rem] uppercase tracking-[0.05em] text-white m-0 leading-[1.2]"
                                        >{exp.title}</h3>
                                        <time
                                            data-i18n={exp.i18nDate}
                                            class="[font-family:'Space_Mono',monospace] text-[0.58rem] text-[#22d3ee] bg-[rgba(34,211,238,0.07)] border border-[rgba(34,211,238,0.18)] py-[2px] px-2 whitespace-nowrap shrink-0 tracking-[0.06em]"
                                        >{exp.date}</time>
                                    </div>
                                    <p
                                        data-i18n={exp.i18nCompany}
                                        class="[font-family:'Space_Mono',monospace] text-[0.62rem] text-[rgba(100,116,139,0.85)] m-0 mb-[0.55rem] tracking-[0.02em]"
                                    >{exp.company}</p>
                                    <p
                                        data-i18n={exp.i18nDesc}
                                        class="text-[0.78rem] text-[rgba(100,116,139,0.9)] leading-[1.75] m-0"
                                    >{exp.description}</p>
                                </div>
                            </article>
                        </div>

                        <!-- Diamond node -->
                        <div
                            class="col-start-2 flex flex-col items-center justify-center relative z-[5] max-sm:col-start-1 max-sm:row-start-1"
                            aria-hidden="true"
                        >
                            <div class="flex flex-col items-center relative">
                                <div class="absolute -inset-1 border border-[rgba(34,211,238,0.45)] rotate-45 animate-pulseDiamond pointer-events-none"></div>
                                <div class="w-[46px] h-[46px] bg-[#030712] border-[1.5px] border-[#22d3ee] rotate-45 flex items-center justify-center shadow-[0_0_18px_rgba(34,211,238,0.22),inset_0_0_14px_rgba(34,211,238,0.06)] transition-[box-shadow,border-color] duration-[350ms] relative z-[1] group-hover:shadow-[0_0_36px_rgba(34,211,238,0.5),inset_0_0_18px_rgba(34,211,238,0.14)] group-hover:border-[#a5f3fc]">
                                    <i class:list={[
                                        exp.icon,
                                        '-rotate-45 text-[#22d3ee] text-[0.9rem] [transition:transform_0.35s_cubic-bezier(0.34,1.56,0.64,1),color_0.35s_ease] group-hover:scale-[1.2] group-hover:text-white'
                                    ]}></i>
                                </div>
                                <span class="[font-family:'Space_Mono',monospace] text-[0.55rem] text-[rgba(34,211,238,0.45)] mt-[7px] tracking-[0.08em]">{num}</span>
                            </div>
                        </div>

                        <!-- Spacer -->
                        <div
                            class:list={['max-sm:hidden', isLeft ? 'col-start-3' : 'col-start-1']}
                            aria-hidden="true"
                        ></div>

                    </div>
                );
            })}

        </div>

    </div>
</section>
