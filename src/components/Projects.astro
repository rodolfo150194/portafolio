const filterOptions: { label: string; tech: string; match?: string[] }[] = [
    { label: 'Python',    tech: 'python' },
    { label: 'Django RF', tech: 'django rest framework' },
    { label: 'Flutter',   tech: 'flutter/dart' },
    { label: 'ASP.NET',   tech: 'asp.net' },
    { label: 'Astro',     tech: 'astro' },
    { label: 'SQL Server', tech: 'sql server' },
    { label: 'MySQL',     tech: 'mysql' },
    { label: 'PostgreSQL', tech: 'postgresql' },
