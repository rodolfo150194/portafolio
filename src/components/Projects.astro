---
const BASE = '/images/fotos%20fe%20proyectos';

const proyectos = [
    {
        id: 1,
        i18nTitle: "proj.0.title",
        titulo: "Agroproductivity Platform",
        i18nDesc: "proj.0.desc",
        descripcion: "Agricultural price system with statistical analysis, price reports, GeoJSON analysis, micro-location visualization and structured REST API.",
        accent: "#10b981",
        placeholderBg: "linear-gradient(135deg, #022c22 0%, #064e3b 40%, #065f46 100%)",
        tecnologias: ["Python", "Django", "Leaflet", "GeoServer"],
        images: [
            `${BASE}/suite%20suelos/1.jpeg`,
            `${BASE}/suite%20suelos/2.jpeg`,
            `${BASE}/suite%20suelos/4.jpeg`,
            `${BASE}/suite%20suelos/5.jpeg`,
            `${BASE}/suite%20suelos/6.jpeg`,
            `${BASE}/suite%20suelos/7.jpeg`,
            `${BASE}/suite%20suelos/8.jpeg`,
            `${BASE}/suite%20suelos/9.jpeg`,
            `${BASE}/suite%20suelos/10.jpg`,
            `${BASE}/suite%20suelos/11.jpg`,
            `${BASE}/suite%20suelos/12.jpg`,
        ]
    },
    {
        id: 2,
        i18nTitle: "proj.1.title",
        titulo: "SICCA (UN - FAO)",
        i18nDesc: "proj.1.desc",
        descripcion: "Climate change platform with artificial intelligence module for decision-making, implementing a custom CMS for recording Cuba's climate actions.",
        accent: "#a78bfa",
        placeholderBg: "linear-gradient(135deg, #1e1035 0%, #2e1065 40%, #3b0764 100%)",
        tecnologias: ["Wagtail", "Django", "AI", "PostgreSQL"],
        images: [
            `${BASE}/sicca/1.png`,
            `${BASE}/sicca/2.png`,
            `${BASE}/sicca/3.jpeg`,
            `${BASE}/sicca/4.jpeg`,
            `${BASE}/sicca/5.jpeg`,
            `${BASE}/sicca/6.jpeg`,
            `${BASE}/acciones%20climaticas/1.jpeg`,
            `${BASE}/acciones%20climaticas/2.jpg`,
            `${BASE}/acciones%20climaticas/3.jpeg`,
            `${BASE}/acciones%20climaticas/4.jpeg`,
            `${BASE}/acciones%20climaticas/5.jpeg`,
            `${BASE}/acciones%20climaticas/8.jpeg`,
        ]
    },
    {
        id: 3,
        i18nTitle: "proj.2.title",
        titulo: "INGEI Platform",
        i18nDesc: "proj.2.desc",
        descripcion: "National Greenhouse Gas Inventory. Visual platform that processes dynamic formulas, analyzes historical series and automatically generates PDF and Excel reports.",
        accent: "#38bdf8",
        placeholderBg: "linear-gradient(135deg, #04232f 0%, #0c4a6e 40%, #082f49 100%)",
        tecnologias: ["FastAPI", "Next.js", "Pandas", "PostgreSQL"],
        images: [
            `${BASE}/ingei/1.jpg`,
            `${BASE}/ingei/2.jpeg`,
            `${BASE}/ingei/3.jpeg`,
            `${BASE}/ingei/4.jpeg`,
            `${BASE}/ingei/5.jpeg`,
            `${BASE}/ingei/6.jpeg`,
            `${BASE}/ingei/7.jpeg`,
            `${BASE}/ingei/8.jpg`,
            `${BASE}/ingei/9.jpeg`,
        ]
    },
    {
        id: 4,
        i18nTitle: "proj.3.title",
        titulo: "GIS App & Bots",
        i18nDesc: "proj.3.desc",
        descripcion: "Android mobile application for building polygons, calculating productive soil areas in real time and interactive Telegram bots for agricultural procedures (Guajapp).",
        accent: "#fb923c",
        placeholderBg: "linear-gradient(135deg, #2c0a00 0%, #7c2d12 40%, #9a3412 100%)",
        tecnologias: ["Android", "Flutter/Dart", "Python", "Telegram API"],
        images: []
    }
];
---

<section id="proyectos" class="projects-section">

    <!-- Header -->
    <div class="projects-header">
        <div class="[font-family:'Space_Mono',monospace] text-[0.65rem] tracking-[0.18em] inline-flex items-center gap-[0.3rem] mb-5">
            <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">[</span>
            <span class="text-[rgba(34,211,238,0.85)]">selected.work</span>
            <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">]</span>
        </div>
        <h2 class="section-heading">
            <span class="heading-ghost">My</span>
            Projects
        </h2>
    </div>

    <!-- List -->
    <div class="projects-list">
        {proyectos.map((proyecto) => (
            <article class="project-card" style={`--accent: ${proyecto.accent};`}>

                <!-- Visual -->
                <div class="card-visual">
                    <div class="browser-frame">
                        <div class="browser-bar">
                            <div class="browser-dots">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                            <div class="browser-url">
                                project-{proyecto.id}.portfolio.dev
                            </div>
                        </div>
                        <div class="browser-viewport" style={`background: ${proyecto.placeholderBg};`}>
                            {proyecto.images.length > 0 ? (
                                <div
                                    class="proj-slideshow group/slide absolute inset-0 cursor-zoom-in"
                                    data-images={JSON.stringify(proyecto.images)}
                                >
                                    {proyecto.images.map((img, idx) => (
                                        <img
                                            src={img}
                                            alt={`${proyecto.titulo} — screenshot ${idx + 1}`}
                                            class={`proj-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ${idx === 0 ? 'opacity-100' : 'opacity-0'}`}
                                            loading={idx === 0 ? 'eager' : 'lazy'}
                                        />
                                    ))}

                                    {proyecto.images.length > 1 && (
                                        <div class="absolute inset-y-0 left-0 right-0 flex items-center justify-between px-2 opacity-0 group-hover/slide:opacity-100 transition-opacity duration-300">
                                            <button class="proj-prev w-8 h-8 rounded-full bg-black/60 backdrop-blur-sm text-white text-xl flex items-center justify-center hover:bg-black/80 transition-colors select-none leading-none">&#8249;</button>
                                            <button class="proj-next w-8 h-8 rounded-full bg-black/60 backdrop-blur-sm text-white text-xl flex items-center justify-center hover:bg-black/80 transition-colors select-none leading-none">&#8250;</button>
                                        </div>
                                    )}

                                    {proyecto.images.length > 1 && (
                                        <div class="absolute bottom-2.5 left-0 right-0 flex justify-center gap-1.5 pointer-events-none">
                                            {proyecto.images.map((_, i) => (
                                                <button class={`proj-dot pointer-events-auto rounded-full transition-all duration-300 h-1.5 ${i === 0 ? 'w-3 bg-white' : 'w-1.5 bg-white/40'}`}></button>
                                            ))}
                                        </div>
                                    )}

                                    <div class="absolute top-2 right-2 opacity-0 group-hover/slide:opacity-100 transition-opacity duration-300 pointer-events-none select-none flex items-center gap-1 bg-black/50 backdrop-blur-sm rounded px-1.5 py-0.5 text-[10px] text-white/70">
                                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
                                        </svg>
                                        Expand
                                    </div>
                                </div>
                            ) : (
                                <div class="viewport-placeholder">
                                    <span class="ph-num">{String(proyecto.id).padStart(2, '0')}</span>
                                    <span class="ph-label">Screenshot coming soon</span>
                                </div>
                            )}
                        </div>
                    </div>
                    <div class="bg-number">{String(proyecto.id).padStart(2, '0')}</div>
                </div>

                <!-- Info -->
                <div class="card-info">
                    <div class="info-meta">
                        <span class="meta-index">{String(proyecto.id).padStart(2, '0')}</span>
                        <div class="meta-rule"></div>
                    </div>

                    <h3 class="info-title" data-i18n={proyecto.i18nTitle}>
                        {proyecto.titulo}
                    </h3>

                    <p class="info-desc" data-i18n={proyecto.i18nDesc}>
                        {proyecto.descripcion}
                    </p>

                    <div class="tech-stack">
                        <span class="stack-label">$ tech --stack</span>
                        <div class="stack-tags">
                            {proyecto.tecnologias.map((tech) => (
                                <span class="stack-tag">{tech}</span>
                            ))}
                        </div>
                    </div>

                    <div class="card-actions">
                        <a href="#" class="action-demo">
                            <span data-i18n="proj.cta.demo">View Demo</span>
                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                            </svg>
                        </a>
                        <a href="#" class="action-github">
                            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                            </svg>
                            GitHub
                        </a>
                        {proyecto.images.length > 0 && (
                            <button
                                class="proj-gallery-btn action-gallery"
                                data-images={JSON.stringify(proyecto.images)}
                            >
                                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 5 2-3 3 6z" clip-rule="evenodd"/>
                                </svg>
                                Gallery ({proyecto.images.length})
                            </button>
                        )}
                    </div>
                </div>

            </article>
        ))}
    </div>

</section>

<style>
    /* Theme variables — set by Tailwind darkMode: 'class' on <html> */
    :root {
        --proj-bg: #f8fafc;
        --proj-heading: #0f172a;
        --proj-info-title: #0f172a;
        --proj-info-desc: #374151;
        --proj-browser-bar: #f1f5f9;
        --proj-browser-border: #e2e8f0;
        --proj-card-border: #e2e8f0;
        --proj-url-color: #6b7280;
        --proj-stack-label: #4b5563;
        --proj-action-github-border: #e2e8f0;
        --proj-action-github-color: #64748b;
        --proj-ghost-stroke: #94a3b8;
    }
    :global(.dark) {
        --proj-bg: #030712;
        --proj-heading: #f1f5f9;
        --proj-info-title: #f1f5f9;
        --proj-info-desc: #8b9ab4;
        --proj-browser-bar: #0d1117;
        --proj-browser-border: #1a2235;
        --proj-card-border: #0f1623;
        --proj-url-color: #3d4f6b;
        --proj-stack-label: #2d3d55;
        --proj-action-github-border: #1a2235;
        --proj-action-github-color: #64748b;
        --proj-ghost-stroke: #2d3748;
    }

    /* ── Section ─────────────────────────────────────────── */
    .projects-section {
        background: var(--proj-bg);
        padding: 7rem 0 10rem;
        position: relative;
        overflow: hidden;
    }

    .projects-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 28px 28px;
        pointer-events: none;
        z-index: 0;
    }

    /* ── Header ──────────────────────────────────────────── */
    .projects-header {
        position: relative;
        z-index: 1;
        max-width: 1320px;
        margin: 0 auto 4.5rem;
        padding: 0 3rem;
    }

    .header-eyebrow {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 0.75rem;
    }

    .eyebrow-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        color: #4b5563;
        letter-spacing: 0.06em;
    }

    .eyebrow-rule {
        width: 140px;
        height: 1px;
        background: linear-gradient(to right, #1f2937, transparent);
    }

    .eyebrow-count {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        color: #374151;
        letter-spacing: 0.1em;
    }

    .section-heading {
        font-family: 'Barlow Condensed', sans-serif;
        font-weight: 900;
        font-size: clamp(4.5rem, 12vw, 9.5rem);
        color: var(--proj-heading);
        line-height: 0.88;
        letter-spacing: -0.01em;
        text-transform: uppercase;
    }

    .heading-ghost {
        display: block;
        color: transparent;
        -webkit-text-stroke: 1px var(--proj-ghost-stroke);
    }

    /* ── Projects List ───────────────────────────────────── */
    .projects-list {
        display: flex;
        flex-direction: column;
        position: relative;
        z-index: 1;
    }

    /* ── Project Card ────────────────────────────────────── */
    .project-card {
        display: grid;
        grid-template-columns: 55% 45%;
        min-height: 62vh;
        border-top: 1px solid var(--proj-card-border);
        opacity: 0;
        transform: translateY(48px);
        transition: opacity 0.75s ease, transform 0.75s ease;
    }

    .project-card.revealed {
        opacity: 1;
        transform: translateY(0);
    }

    .project-card:nth-child(even) {
        grid-template-columns: 45% 55%;
    }

    .project-card:nth-child(even) .card-visual {
        order: 2;
    }

    .project-card:nth-child(even) .card-info {
        order: 1;
    }

    /* ── Visual Column ───────────────────────────────────── */
    .card-visual {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3.5rem 2.5rem;
        overflow: hidden;
    }

    .bg-number {
        position: absolute;
        bottom: -8%;
        right: -6%;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 22vw;
        color: var(--accent);
        opacity: 0.035;
        line-height: 1;
        pointer-events: none;
        user-select: none;
        z-index: 0;
        transition: opacity 0.5s ease;
    }

    .project-card:hover .bg-number {
        opacity: 0.065;
    }

    /* ── Browser Frame ───────────────────────────────────── */
    .browser-frame {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 620px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--proj-browser-border);
        box-shadow:
            0 0 0 1px rgba(255,255,255,0.025),
            0 24px 64px rgba(0,0,0,0.65),
            0 4px 16px rgba(0,0,0,0.4);
        transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                    box-shadow 0.5s ease;
    }

    .project-card:hover .browser-frame {
        transform: scale(1.018) translateY(-5px);
        box-shadow:
            0 0 0 1px rgba(255,255,255,0.05),
            0 36px 80px rgba(0,0,0,0.75),
            0 4px 16px rgba(0,0,0,0.5);
    }

    .browser-bar {
        background: var(--proj-browser-bar);
        padding: 9px 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid var(--proj-browser-border);
    }

    .browser-dots {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .browser-dots span {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .browser-dots span:nth-child(1) { background: #e74c3c; }
    .browser-dots span:nth-child(2) { background: #f39c12; }
    .browser-dots span:nth-child(3) { background: #2ecc71; }

    .browser-url {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
        color: var(--proj-url-color);
        flex: 1;
        text-align: center;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .browser-viewport {
        aspect-ratio: 16/10;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }

    .project-screenshot {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .viewport-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        pointer-events: none;
    }

    .ph-num {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 5.5rem;
        color: var(--accent);
        opacity: 0.3;
        line-height: 1;
    }

    .ph-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.62rem;
        color: rgba(255,255,255,0.18);
        text-transform: uppercase;
        letter-spacing: 0.22em;
    }

    /* ── Info Column ─────────────────────────────────────── */
    .card-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 4rem 4.5rem 4rem 3.5rem;
        gap: 1.6rem;
    }

    .project-card:nth-child(even) .card-info {
        padding: 4rem 3.5rem 4rem 4.5rem;
    }

    .info-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .meta-index {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--accent);
        letter-spacing: 0.05em;
    }

    .meta-rule {
        width: 36px;
        height: 1px;
        background: var(--accent);
        opacity: 0.45;
    }

    .info-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(2.25rem, 3.5vw, 3.5rem);
        color: var(--proj-info-title);
        line-height: 1.0;
        letter-spacing: 0.025em;
    }

    .info-desc {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.975rem;
        line-height: 1.78;
        color: var(--proj-info-desc);
        max-width: 44ch;
        font-weight: 400;
    }

    /* ── Tech Stack ──────────────────────────────────────── */
    .tech-stack {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .stack-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
        color: var(--proj-stack-label);
        letter-spacing: 0.1em;
    }

    .stack-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .stack-tag {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.28rem 0.75rem;
        border-radius: 4px;
        color: var(--accent);
        border: 1px solid rgba(255, 255, 255, 0.07);
        background: rgba(255, 255, 255, 0.03);
        transition: background 0.2s ease;
    }

    @supports (color: color-mix(in srgb, red 10%, transparent)) {
        .stack-tag {
            border-color: color-mix(in srgb, var(--accent) 22%, transparent);
            background: color-mix(in srgb, var(--accent) 6%, transparent);
        }

        .stack-tag:hover {
            background: color-mix(in srgb, var(--accent) 14%, transparent);
        }
    }

    /* ── Actions ─────────────────────────────────────────── */
    .card-actions {
        display: flex;
        gap: 0.875rem;
        align-items: center;
        flex-wrap: wrap;
        margin-top: 0.25rem;
    }

    .action-demo {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.65rem 1.4rem;
        border-radius: 6px;
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        background: var(--accent);
        color: #030712;
        transition: opacity 0.2s, transform 0.2s;
    }

    .action-demo svg {
        width: 0.9rem;
        height: 0.9rem;
        transition: transform 0.2s ease;
    }

    .action-demo:hover {
        opacity: 0.85;
        transform: translateY(-2px);
    }

    .action-demo:hover svg {
        transform: translateX(3px);
    }

    .action-github {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.65rem 1.2rem;
        border-radius: 6px;
        border: 1px solid var(--proj-action-github-border);
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--proj-action-github-color);
        text-decoration: none;
        transition: border-color 0.2s, color 0.2s;
    }

    .action-github svg {
        width: 0.95rem;
        height: 0.95rem;
    }

    .action-github:hover {
        border-color: var(--proj-ghost-stroke);
        color: #94a3b8;
    }

    .action-gallery {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.65rem 1.1rem;
        border-radius: 6px;
        border: 1px solid rgba(255,255,255,0.06);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        font-weight: 500;
        color: #4b6080;
        background: transparent;
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s, background 0.2s;
        letter-spacing: 0.04em;
    }

    .action-gallery svg {
        width: 0.9rem;
        height: 0.9rem;
    }

    .action-gallery:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: color-mix(in srgb, var(--accent) 8%, transparent);
    }

    /* ── Responsive ──────────────────────────────────────── */
    @media (max-width: 960px) {
        .project-card,
        .project-card:nth-child(even) {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .project-card:nth-child(even) .card-visual { order: 0; }
        .project-card:nth-child(even) .card-info { order: 0; }

        .card-visual {
            padding: 2.5rem 2rem;
            min-height: 260px;
        }

        .card-info,
        .project-card:nth-child(even) .card-info {
            padding: 2rem 2rem 3rem;
            gap: 1.25rem;
        }

        .bg-number {
            font-size: 45vw;
        }
    }

    @media (max-width: 600px) {
        .projects-header {
            padding: 0 1.5rem;
            margin-bottom: 3rem;
        }

        .card-visual { padding: 2rem 1.25rem; }
        .card-info,
        .project-card:nth-child(even) .card-info {
            padding: 1.5rem 1.25rem 2.5rem;
        }

        .info-desc { max-width: 100%; }
    }
</style>

<script is:inline>
(function () {

    /* ── Lightbox ──────────────────────────────────────────── */
    var lbImages = [];
    var lbIndex  = 0;

    function buildLightbox() {
        if (document.getElementById('proj-lightbox')) return;
        var wrap = document.createElement('div');
        wrap.innerHTML =
            '<div id="proj-lightbox" style="' +
              'position:fixed;inset:0;z-index:9999;' +
              'display:flex;align-items:center;justify-content:center;' +
              'background:rgba(2,4,14,0.96);backdrop-filter:blur(10px);' +
              'transition:opacity 0.3s;opacity:0;pointer-events:none;">' +
              '<button id="lb-close" style="' +
                'position:absolute;top:1.25rem;right:1.5rem;' +
                'width:2.5rem;height:2.5rem;border-radius:50%;' +
                'display:flex;align-items:center;justify-content:center;' +
                'background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);' +
                'color:#fff;font-size:1.4rem;cursor:pointer;line-height:1;' +
                'transition:background 0.2s;">&#215;</button>' +
              '<button id="lb-prev" style="' +
                'position:absolute;left:1.25rem;' +
                'width:3rem;height:3rem;border-radius:50%;' +
                'display:flex;align-items:center;justify-content:center;' +
                'background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);' +
                'color:#fff;font-size:2rem;cursor:pointer;line-height:1;' +
                'transition:background 0.2s;">&#8249;</button>' +
              '<img id="lb-img" style="' +
                'max-height:85vh;max-width:88vw;object-fit:contain;' +
                'border-radius:8px;box-shadow:0 30px 90px rgba(0,0,0,0.85);' +
                'transition:opacity 0.18s;" src="" alt="" />' +
              '<button id="lb-next" style="' +
                'position:absolute;right:1.25rem;' +
                'width:3rem;height:3rem;border-radius:50%;' +
                'display:flex;align-items:center;justify-content:center;' +
                'background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);' +
                'color:#fff;font-size:2rem;cursor:pointer;line-height:1;' +
                'transition:background 0.2s;">&#8250;</button>' +
              '<div id="lb-counter" style="' +
                'position:absolute;bottom:1.5rem;left:50%;transform:translateX(-50%);' +
                'font-family:JetBrains Mono,monospace;font-size:0.75rem;' +
                'color:rgba(255,255,255,0.4);letter-spacing:0.12em;"></div>' +
            '</div>';
        document.body.appendChild(wrap.firstChild);

        document.getElementById('lb-close').onclick = closeLb;
        document.getElementById('lb-prev').onclick  = function() { navLb(-1); };
        document.getElementById('lb-next').onclick  = function() { navLb(1); };
        document.getElementById('proj-lightbox').onclick = function(e) {
            if (e.target === this) closeLb();
        };
        document.addEventListener('keydown', function(e) {
            var lb = document.getElementById('proj-lightbox');
            if (!lb || lb.style.pointerEvents === 'none') return;
            if (e.key === 'Escape')      closeLb();
            if (e.key === 'ArrowLeft')  navLb(-1);
            if (e.key === 'ArrowRight') navLb(1);
        });
    }

    function openLb(images, startIdx) {
        buildLightbox();
        lbImages = images;
        lbIndex  = startIdx;
        updateLb();
        var lb = document.getElementById('proj-lightbox');
        lb.style.opacity       = '1';
        lb.style.pointerEvents = 'auto';
        document.body.style.overflow = 'hidden';
    }

    function closeLb() {
        var lb = document.getElementById('proj-lightbox');
        if (!lb) return;
        lb.style.opacity       = '0';
        lb.style.pointerEvents = 'none';
        document.body.style.overflow = '';
    }

    function navLb(dir) {
        lbIndex = (lbIndex + dir + lbImages.length) % lbImages.length;
        updateLb();
    }

    function updateLb() {
        var img     = document.getElementById('lb-img');
        var counter = document.getElementById('lb-counter');
        if (img)     img.src = lbImages[lbIndex];
        if (counter) counter.textContent = (lbIndex + 1) + ' / ' + lbImages.length;
    }

    /* ── Slideshows ────────────────────────────────────────── */
    function initSlideshows() {
        document.querySelectorAll('.proj-slideshow').forEach(function(container) {
            if (container.__ssInit) return;
            container.__ssInit = true;

            var images  = JSON.parse(container.dataset.images || '[]');
            var slides  = container.querySelectorAll('.proj-slide');
            var dots    = container.querySelectorAll('.proj-dot');
            var prevBtn = container.querySelector('.proj-prev');
            var nextBtn = container.querySelector('.proj-next');
            var cur     = 0;
            var timer   = null;

            function goTo(idx) {
                slides[cur].style.opacity = '0';
                if (dots[cur]) { dots[cur].style.width = '6px'; dots[cur].style.background = 'rgba(255,255,255,0.4)'; }
                cur = (idx + slides.length) % slides.length;
                slides[cur].style.opacity = '1';
                if (dots[cur]) { dots[cur].style.width = '12px'; dots[cur].style.background = '#fff'; }
            }

            function startAuto() { timer = setInterval(function() { goTo(cur + 1); }, 4500); }
            function stopAuto()  { clearInterval(timer); }

            if (prevBtn) prevBtn.addEventListener('click', function(e) { e.stopPropagation(); stopAuto(); goTo(cur - 1); startAuto(); });
            if (nextBtn) nextBtn.addEventListener('click', function(e) { e.stopPropagation(); stopAuto(); goTo(cur + 1); startAuto(); });

            dots.forEach(function(dot, i) {
                dot.addEventListener('click', function(e) { e.stopPropagation(); stopAuto(); goTo(i); startAuto(); });
            });

            container.addEventListener('click', function() { openLb(images, cur); });

            startAuto();
        });
    }

    /* ── Gallery buttons ───────────────────────────────────── */
    function initGalleryBtns() {
        document.querySelectorAll('.proj-gallery-btn').forEach(function(btn) {
            if (btn.__galleryInit) return;
            btn.__galleryInit = true;
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var images = JSON.parse(btn.dataset.images || '[]');
                if (images.length) openLb(images, 0);
            });
        });
    }

    /* ── Reveal animation ──────────────────────────────────── */
    function initReveal() {
        var cards = document.querySelectorAll('.project-card');
        if (!cards.length) return;
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('revealed');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
        cards.forEach(function(card) { observer.observe(card); });
    }

    function init() {
        initReveal();
        initSlideshows();
        initGalleryBtns();
    }

    document.addEventListener('astro:page-load', init);
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
