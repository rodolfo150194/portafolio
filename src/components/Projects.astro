---

<section
    id="proyectos"
    class="bg-slate-50 dark:bg-[#030712] pt-28 pb-40 relative overflow-hidden"
>
    <!-- Dot grid overlay -->
    <div class="absolute inset-0 pointer-events-none z-0 [background-image:radial-gradient(circle,rgba(255,255,255,0.025)_1px,transparent_1px)] [background-size:28px_28px]"></div>

    <!-- Header -->
    <div class="relative z-10 max-w-[1320px] mx-auto px-6 mb-12 sm:px-12 sm:mb-[4.5rem] text-center">
        <div class="font-space text-[0.65rem] tracking-[0.18em] inline-flex items-center gap-[0.3rem] mb-5">
            <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">[</span>
            <span class="text-[rgba(34,211,238,0.85)]">selected.work</span>
            <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">]</span>
        </div>
        <h2 class="font-barlow font-black text-[clamp(2.5rem,7vw,4.5rem)] text-slate-900 dark:text-slate-100 leading-[0.88] tracking-[-0.01em] uppercase">
            <span class="text-transparent [-webkit-text-stroke:2px_#22d3ee]">My</span>
            Projects
        </h2>
    </div>

    <!-- Search + Filter -->
    <div class="relative z-10 max-w-[1320px] mx-auto px-6 sm:px-12 mb-10 sm:mb-14">
        <!-- Search input -->
        <div class="relative mb-5">
            <div class="absolute inset-y-0 left-3.5 flex items-center pointer-events-none">
                <svg class="w-4 h-4 text-slate-400 dark:text-[#3d4f6b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
            </div>
            <input
                id="proj-search"
                type="text"
                placeholder="Search projects..."
                class="w-full bg-white dark:bg-[#080e1a] border border-slate-200 dark:border-[#0f1623] rounded-[8px] pl-10 pr-4 py-3 font-jetbrains text-[0.875rem] text-slate-700 dark:text-slate-300 placeholder:text-slate-400 dark:placeholder:text-[#3d4f6b] outline-none focus:border-slate-400 dark:focus:border-[#2d3748] transition-colors duration-200"
            />
        </div>

        <!-- Tech filter pills -->
        <div class="flex flex-wrap gap-[0.4rem]">
            <button
                class="proj-tech-filter font-jetbrains text-[0.7rem] py-1 px-[0.75rem] rounded border tracking-[0.06em] cursor-pointer transition-all duration-200 border-slate-200 dark:border-[#1a2235] text-slate-500 dark:text-[#4b6080] hover:border-cyan-400/30 hover:text-cyan-400 hover:bg-cyan-400/5 data-[active=true]:border-cyan-400/30 data-[active=true]:text-cyan-400 data-[active=true]:bg-cyan-400/10"
                data-tech="all"
                data-active="true"
            >
                All
            </button>
            {filterOptions.map((f) => (
                <button
                    class="proj-tech-filter font-jetbrains text-[0.7rem] py-1 px-[0.75rem] rounded border tracking-[0.06em] cursor-pointer transition-all duration-200 border-slate-200 dark:border-[#1a2235] text-slate-500 dark:text-[#4b6080] hover:border-cyan-400/30 hover:text-cyan-400 hover:bg-cyan-400/5 data-[active=true]:border-cyan-400/30 data-[active=true]:text-cyan-400 data-[active=true]:bg-cyan-400/10"
                    data-tech={f.tech}
                    data-match={f.match ? JSON.stringify(f.match) : undefined}
                >
                    {f.label}
                </button>
            ))}
        </div>
    </div>

    <!-- No results -->
    <div id="proj-no-results" style="display:none" class="relative z-10 flex flex-col items-center justify-center py-24 text-center">
        <span class="font-jetbrains text-[0.75rem] text-slate-400 dark:text-[#3d4f6b] tracking-[0.15em] mb-2">// no_results_found</span>
        <p class="font-body text-slate-500 dark:text-[#4b6080] text-[0.9rem]">Try a different search or filter</p>
    </div>

    <!-- List -->
    <div class="flex flex-col relative z-10">
        {proyectos.map((proyecto, idx) => {
            const isEven = idx % 2 === 1;
            return (
                <article
                    class={[
                        'group project-card',
                        'grid grid-cols-1',
                        'min-[960px]:min-h-[62vh]',
                        isEven ? 'min-[960px]:grid-cols-[45%_55%]' : 'min-[960px]:grid-cols-[55%_45%]',
                        'border-t border-slate-200 dark:border-[#0f1623]',
                        'opacity-0 translate-y-12',
                        'transition-[opacity,transform] duration-700 ease-out',
                    ].join(' ')}
                    style={`--accent: ${proyecto.accent};`}
                    data-title={proyecto.titulo.toLowerCase()}
                    data-techs={proyecto.tecnologias.map(t => t.toLowerCase()).join(',')}
                >
                    <!-- Visual column -->
                    <div class={[
                        'relative flex items-center justify-center overflow-hidden',
                        'min-h-[260px] min-[960px]:min-h-0',
                        'py-8 px-5 sm:py-10 sm:px-8 min-[960px]:py-14 min-[960px]:px-10',
                        isEven ? 'min-[960px]:order-2' : '',
                    ].join(' ')}>

                        <!-- Browser frame -->
                        <div class="relative z-10 w-full max-w-[620px] rounded-[10px] overflow-hidden border border-slate-200 dark:border-[#1a2235] shadow-[0_0_0_1px_rgba(255,255,255,0.025),0_24px_64px_rgba(0,0,0,0.65),0_4px_16px_rgba(0,0,0,0.4)] transition-[transform,box-shadow] duration-500 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] group-hover:scale-[1.018] group-hover:-translate-y-[5px] group-hover:shadow-[0_0_0_1px_rgba(255,255,255,0.05),0_36px_80px_rgba(0,0,0,0.75),0_4px_16px_rgba(0,0,0,0.5)]">

                            <!-- Browser bar -->
                            <div class="bg-slate-100 dark:bg-[#0d1117] py-[9px] px-3.5 flex items-center gap-2.5 border-b border-slate-200 dark:border-[#1a2235]">
                                <div class="flex gap-1.5 shrink-0">
                                    <span class="w-2.5 h-2.5 rounded-full bg-[#e74c3c]"></span>
                                    <span class="w-2.5 h-2.5 rounded-full bg-[#f39c12]"></span>
                                    <span class="w-2.5 h-2.5 rounded-full bg-[#2ecc71]"></span>
                                </div>
                                <div class="font-jetbrains text-[0.68rem] text-gray-500 dark:text-[#3d4f6b] flex-1 text-center overflow-hidden text-ellipsis whitespace-nowrap">
                                    project-{proyecto.id}.portfolio.dev
                                </div>
                            </div>

                            <!-- Viewport -->
                            <div
                                class="aspect-[16/10] flex items-center justify-center overflow-hidden relative"
                                style={`background: ${proyecto.placeholderBg};`}
                            >
                                {proyecto.images.length > 0 ? (
                                    <div
                                        class="proj-slideshow group/slide absolute inset-0 cursor-zoom-in"
                                        data-images={JSON.stringify(proyecto.images)}
                                    >
                                        {proyecto.images.map((img, i) => (
                                            <img
                                                src={img}
                                                alt={`${proyecto.titulo} — screenshot ${i + 1}`}
                                                class={`proj-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
                                                loading={i === 0 ? 'eager' : 'lazy'}
                                            />
                                        ))}

                                        {proyecto.images.length > 1 && (
                                            <div class="absolute inset-y-0 left-0 right-0 flex items-center justify-between px-2 opacity-0 group-hover/slide:opacity-100 transition-opacity duration-300">
                                                <button class="proj-prev w-8 h-8 rounded-full bg-black/60 backdrop-blur-sm text-white text-xl flex items-center justify-center hover:bg-black/80 transition-colors select-none leading-none">&#8249;</button>
                                                <button class="proj-next w-8 h-8 rounded-full bg-black/60 backdrop-blur-sm text-white text-xl flex items-center justify-center hover:bg-black/80 transition-colors select-none leading-none">&#8250;</button>
                                            </div>
                                        )}

                                        {proyecto.images.length > 1 && (
                                            <div class="absolute bottom-2.5 left-0 right-0 flex justify-center gap-1.5 pointer-events-none">
                                                {proyecto.images.map((_, i) => (
                                                    <button class={`proj-dot pointer-events-auto rounded-full transition-all duration-300 h-1.5 ${i === 0 ? 'w-3 bg-white' : 'w-1.5 bg-white/40'}`}></button>
                                                ))}
                                            </div>
                                        )}

                                        <div class="absolute top-2 right-2 opacity-0 group-hover/slide:opacity-100 transition-opacity duration-300 pointer-events-none select-none flex items-center gap-1 bg-black/50 backdrop-blur-sm rounded px-1.5 py-0.5 text-[10px] text-white/70">
                                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
                                            </svg>
                                            Expand
                                        </div>
                                    </div>
                                ) : (
                                    <div class="flex flex-col items-center gap-1.5 pointer-events-none">
                                        <span class="font-bebas text-[5.5rem] [color:var(--accent)] opacity-30 leading-none">
                                            {String(proyecto.id).padStart(2, '0')}
                                        </span>
                                        <span class="font-jetbrains text-[0.62rem] text-white/[0.18] uppercase tracking-[0.22em]">
                                            Screenshot coming soon
                                        </span>
                                    </div>
                                )}
                            </div>
                        </div>

                        <!-- Background number -->
                        <div class="absolute bottom-[-8%] right-[-6%] font-bebas text-[45vw] min-[960px]:text-[22vw] [color:var(--accent)] opacity-[0.035] group-hover:opacity-[0.065] leading-none pointer-events-none select-none z-0 transition-opacity duration-500">
                            {String(proyecto.id).padStart(2, '0')}
                        </div>
                    </div>

                    <!-- Info column -->
                    <div class={[
                        'flex flex-col justify-center',
                        'py-6 px-5 pb-10 gap-5',
                        'sm:py-8 sm:px-8 sm:pb-12',
                        'min-[960px]:gap-[1.6rem]',
                        isEven
                            ? 'min-[960px]:order-1 min-[960px]:py-16 min-[960px]:pr-14 min-[960px]:pl-[4.5rem]'
                            : 'min-[960px]:py-16 min-[960px]:pl-14 min-[960px]:pr-[4.5rem]',
                    ].join(' ')}>

                        <!-- Meta index -->
                        <div class="flex items-center gap-3">
                            <span class="font-jetbrains text-[0.82rem] font-medium [color:var(--accent)] tracking-[0.05em]">
                                {String(proyecto.id).padStart(2, '0')}
                            </span>
                            <div class="w-9 h-px [background:var(--accent)] opacity-[0.45]"></div>
                        </div>

                        <h3
                            class="font-bebas text-[clamp(2.25rem,3.5vw,3.5rem)] text-slate-900 dark:text-slate-100 leading-none tracking-[0.025em]"
                            data-i18n={proyecto.i18nTitle}
                        >
                            {proyecto.titulo}
                        </h3>

                        <p
                            class="font-body text-[0.975rem] leading-[1.78] text-gray-700 dark:text-[#8b9ab4] max-w-full sm:max-w-[44ch] font-normal"
                            data-i18n={proyecto.i18nDesc}
                        >
                            {proyecto.descripcion}
                        </p>

                        <!-- Tech stack -->
                        <div class="flex flex-col gap-[0.6rem]">
                            <span class="font-jetbrains text-[0.68rem] text-gray-600 dark:text-[#2d3d55] tracking-[0.1em]">$ tech --stack</span>
                            <div class="flex flex-wrap gap-[0.45rem]">
                                {proyecto.tecnologias.map((tech) => (
                                    <span class="font-jetbrains text-[0.75rem] font-medium py-[0.28rem] px-3 rounded [color:var(--accent)] border [border-color:color-mix(in_srgb,var(--accent)_22%,transparent)] [background:color-mix(in_srgb,var(--accent)_6%,transparent)] hover:[background:color-mix(in_srgb,var(--accent)_14%,transparent)] transition-colors duration-200">
                                        {tech}
                                    </span>
                                ))}
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex gap-[0.875rem] items-center flex-wrap mt-1">
                            {proyecto.demo && (
                                <a href={proyecto.demo} target="_blank" rel="noopener noreferrer" class="group/demo inline-flex items-center gap-2 py-[0.65rem] px-[1.4rem] rounded-[6px] font-body text-[0.875rem] font-semibold no-underline [background:var(--accent)] text-[#030712] transition-[opacity,transform] duration-200 hover:opacity-85 hover:-translate-y-0.5">
                                    <span data-i18n="proj.cta.demo">Visitar</span>
                                    <svg class="w-[0.9rem] h-[0.9rem] transition-transform duration-200 group-hover/demo:translate-x-[3px]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                                    </svg>
                                </a>
                            )}

                            {proyecto.github && (
                                <a href={proyecto.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 py-[0.65rem] px-[1.2rem] rounded-[6px] border border-slate-200 dark:border-[#1a2235] font-body text-[0.875rem] font-medium text-slate-500 no-underline transition-[border-color,color] duration-200 hover:border-slate-400 dark:hover:border-[#2d3748] hover:text-slate-400">
                                    <svg class="w-[0.95rem] h-[0.95rem]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                    </svg>
                                    GitHub
                                </a>
                            )}

                            {!proyecto.demo && !proyecto.github && (
                                <span class="inline-flex items-center gap-[0.4rem] py-[0.55rem] px-[1rem] rounded-[6px] border border-slate-200/60 dark:border-[#1a2235] font-jetbrains text-[0.68rem] tracking-[0.08em] text-slate-400 dark:text-[#3d4f6b]">
                                    <svg class="w-[0.8rem] h-[0.8rem] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                    </svg>
                                    Confidential — Enterprise
                                </span>
                            )}

                            {proyecto.images.length > 0 && (
                                <button
                                    class="proj-gallery-btn inline-flex items-center gap-[0.45rem] py-[0.65rem] px-[1.1rem] rounded-[6px] border border-white/[0.06] font-jetbrains text-[0.72rem] font-medium text-[#4b6080] bg-transparent cursor-pointer tracking-[0.04em] transition-[border-color,color,background] duration-200 hover:[border-color:var(--accent)] hover:[color:var(--accent)] hover:[background:color-mix(in_srgb,var(--accent)_8%,transparent)]"
                                    data-images={JSON.stringify(proyecto.images)}
                                >
                                    <svg class="w-[0.9rem] h-[0.9rem]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 5 2-3 3 6z" clip-rule="evenodd"/>
                                    </svg>
                                    Gallery ({proyecto.images.length})
                                </button>
                            )}
                        </div>
                    </div>
                </article>
            );
        })}
    </div>
</section>

<script is:inline>
(function () {

    /* ── Lightbox ──────────────────────────────────────────── */
    var lbImages = [];
    var lbIndex  = 0;

    function buildLightbox() {
        if (document.getElementById('proj-lightbox')) return;
        var wrap = document.createElement('div');
        wrap.innerHTML =
            '<div id="proj-lightbox" style="' +
              'position:fixed;inset:0;z-index:9999;' +
              'display:flex;align-items:center;justify-content:center;' +
              'background:rgba(2,4,14,0.96);backdrop-filter:blur(10px);' +
              'transition:opacity 0.3s;opacity:0;pointer-events:none;">' +
              '<button id="lb-close" style="' +
                'position:absolute;top:1.25rem;right:1.5rem;' +
                'width:2.5rem;height:2.5rem;border-radius:50%;' +
                'display:flex;align-items:center;justify-content:center;' +
                'background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);' +
                'color:#fff;font-size:1.4rem;cursor:pointer;line-height:1;' +
                'transition:background 0.2s;">&#215;</button>' +
              '<button id="lb-prev" style="' +
                'position:absolute;left:1.25rem;' +
                'width:3rem;height:3rem;border-radius:50%;' +
                'display:flex;align-items:center;justify-content:center;' +
                'background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);' +
                'color:#fff;font-size:2rem;cursor:pointer;line-height:1;' +
                'transition:background 0.2s;">&#8249;</button>' +
              '<img id="lb-img" style="' +
                'max-height:85vh;max-width:88vw;object-fit:contain;' +
                'border-radius:8px;box-shadow:0 30px 90px rgba(0,0,0,0.85);' +
                'transition:opacity 0.18s;" src="" alt="" />' +
              '<button id="lb-next" style="' +
                'position:absolute;right:1.25rem;' +
                'width:3rem;height:3rem;border-radius:50%;' +
                'display:flex;align-items:center;justify-content:center;' +
                'background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);' +
                'color:#fff;font-size:2rem;cursor:pointer;line-height:1;' +
                'transition:background 0.2s;">&#8250;</button>' +
              '<div id="lb-counter" style="' +
                'position:absolute;bottom:1.5rem;left:50%;transform:translateX(-50%);' +
                'font-family:JetBrains Mono,monospace;font-size:0.75rem;' +
                'color:rgba(255,255,255,0.4);letter-spacing:0.12em;"></div>' +
            '</div>';
        document.body.appendChild(wrap.firstChild);

        document.getElementById('lb-close').onclick = closeLb;
        document.getElementById('lb-prev').onclick  = function() { navLb(-1); };
        document.getElementById('lb-next').onclick  = function() { navLb(1); };
        document.getElementById('proj-lightbox').onclick = function(e) {
            if (e.target === this) closeLb();
        };
        document.addEventListener('keydown', function(e) {
            var lb = document.getElementById('proj-lightbox');
            if (!lb || lb.style.pointerEvents === 'none') return;
            if (e.key === 'Escape')      closeLb();
            if (e.key === 'ArrowLeft')  navLb(-1);
            if (e.key === 'ArrowRight') navLb(1);
        });
    }

    function openLb(images, startIdx) {
        buildLightbox();
        lbImages = images;
        lbIndex  = startIdx;
        updateLb();
        var lb = document.getElementById('proj-lightbox');
        lb.style.opacity       = '1';
        lb.style.pointerEvents = 'auto';
        document.body.style.overflow = 'hidden';
    }

    function closeLb() {
        var lb = document.getElementById('proj-lightbox');
        if (!lb) return;
        lb.style.opacity       = '0';
        lb.style.pointerEvents = 'none';
        document.body.style.overflow = '';
    }

    function navLb(dir) {
        lbIndex = (lbIndex + dir + lbImages.length) % lbImages.length;
        updateLb();
    }

    function updateLb() {
        var img     = document.getElementById('lb-img');
        var counter = document.getElementById('lb-counter');
        if (img)     img.src = lbImages[lbIndex];
        if (counter) counter.textContent = (lbIndex + 1) + ' / ' + lbImages.length;
    }

    /* ── Slideshows ────────────────────────────────────────── */
    function initSlideshows() {
        document.querySelectorAll('.proj-slideshow').forEach(function(container) {
            if (container.__ssInit) return;
            container.__ssInit = true;

            var images  = JSON.parse(container.dataset.images || '[]');
            var slides  = container.querySelectorAll('.proj-slide');
            var dots    = container.querySelectorAll('.proj-dot');
            var prevBtn = container.querySelector('.proj-prev');
            var nextBtn = container.querySelector('.proj-next');
            var cur     = 0;
            var timer   = null;

            function goTo(idx) {
                slides[cur].style.opacity = '0';
                if (dots[cur]) { dots[cur].style.width = '6px'; dots[cur].style.background = 'rgba(255,255,255,0.4)'; }
                cur = (idx + slides.length) % slides.length;
                slides[cur].style.opacity = '1';
                if (dots[cur]) { dots[cur].style.width = '12px'; dots[cur].style.background = '#fff'; }
            }

            function startAuto() { timer = setInterval(function() { goTo(cur + 1); }, 4500); }
            function stopAuto()  { clearInterval(timer); }

            if (prevBtn) prevBtn.addEventListener('click', function(e) { e.stopPropagation(); stopAuto(); goTo(cur - 1); startAuto(); });
            if (nextBtn) nextBtn.addEventListener('click', function(e) { e.stopPropagation(); stopAuto(); goTo(cur + 1); startAuto(); });

            dots.forEach(function(dot, i) {
                dot.addEventListener('click', function(e) { e.stopPropagation(); stopAuto(); goTo(i); startAuto(); });
            });

            container.addEventListener('click', function() { openLb(images, cur); });

            startAuto();
        });
    }

    /* ── Gallery buttons ───────────────────────────────────── */
    function initGalleryBtns() {
        document.querySelectorAll('.proj-gallery-btn').forEach(function(btn) {
            if (btn.__galleryInit) return;
            btn.__galleryInit = true;
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var images = JSON.parse(btn.dataset.images || '[]');
                if (images.length) openLb(images, 0);
            });
        });
    }

    /* ── Reveal animation ──────────────────────────────────── */
    function initReveal() {
        var cards = document.querySelectorAll('.project-card');
        if (!cards.length) return;
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.remove('opacity-0', 'translate-y-12');
                    entry.target.classList.add('opacity-100', 'translate-y-0');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
        cards.forEach(function(card) { observer.observe(card); });
    }

    /* ── Search + Filter ──────────────────────────────────── */
    function initFilter() {
        var searchInput = document.getElementById('proj-search');
        var techBtns    = document.querySelectorAll('.proj-tech-filter');
        var cards       = document.querySelectorAll('.project-card');
        var noResults   = document.getElementById('proj-no-results');

        var activeSearch    = '';
        var activeTech      = 'all';
        var activeMatchList = null;

        function applyFilters() {
            var visible = 0;
            cards.forEach(function(card) {
                var title = card.dataset.title || '';
                var techs = card.dataset.techs  || '';
                var techArr = techs.split(',');
                var matchSearch = !activeSearch || title.indexOf(activeSearch) !== -1;
                var matchTech;
                if (activeTech === 'all') {
                    matchTech = true;
                } else if (activeMatchList) {
                    matchTech = activeMatchList.some(function(m) { return techArr.indexOf(m) !== -1; });
                } else {
                    matchTech = techArr.indexOf(activeTech) !== -1;
                }
                if (matchSearch && matchTech) {
                    card.style.display = '';
                    visible++;
                } else {
                    card.style.display = 'none';
                }
            });
            if (noResults) noResults.style.display = visible === 0 ? 'flex' : 'none';
        }

        if (searchInput) {
            searchInput.addEventListener('input', function() {
                activeSearch = this.value.trim().toLowerCase();
                applyFilters();
            });
        }

        techBtns.forEach(function(btn) {
            btn.addEventListener('click', function() {
                techBtns.forEach(function(b) { delete b.dataset.active; });
                this.dataset.active = 'true';
                activeTech      = this.dataset.tech.toLowerCase();
                activeMatchList = this.dataset.match ? JSON.parse(this.dataset.match) : null;
                applyFilters();
            });
        });
    }

    function init() {
        initReveal();
        initSlideshows();
        initGalleryBtns();
        initFilter();
    }

    document.addEventListener('astro:page-load', init);
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
