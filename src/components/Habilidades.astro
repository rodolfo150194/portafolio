---
const skillCategories = [
    {
        i18nKey: "skills.cat.0",
        title: "Backend",
        icon: "fa-solid fa-terminal",
        accent: "text-emerald-400 bg-emerald-400/10 border-emerald-400/20",
        skills: ["Python", "Django", "FastAPI", "Django REST Framework (DRF)"]
    },
    {
        i18nKey: "skills.cat.1",
        title: "Frontend",
        icon: "fa-solid fa-globe",
        accent: "text-blue-400 bg-blue-400/10 border-blue-400/20",
        skills: ["JavaScript", "Next.js", "Astro", "Tailwind CSS", "Flutter / Dart", "Leaflet"]
    },
    {
        i18nKey: "skills.cat.2",
        title: "Databases",
        icon: "fa-solid fa-database",
        accent: "text-amber-400 bg-amber-400/10 border-amber-400/20",
        skills: ["PostgreSQL", "MySQL"]
    },
    {
        i18nKey: "skills.cat.3",
        title: "Infrastructure & DevOps",
        icon: "fa-solid fa-server",
        accent: "text-violet-400 bg-violet-400/10 border-violet-400/20",
        skills: ["Linux", "Windows Server / AD", "LAN / WAN / Routers", "Security Policies", "Backups / DR", "Git & GitHub"]
    },
    {
        i18nKey: "skills.cat.4",
        title: "QA & Testing",
        icon: "fa-solid fa-flask-vial",
        accent: "text-rose-400 bg-rose-400/10 border-rose-400/20",
        skills: ["Pytest", "Django Test Framework", "Selenium", "Playwright", "Postman", "Coverage.py"]
    }
];
---

<section id="habilidades" class="relative py-24 bg-gray-950 overflow-hidden">

    <!-- Background ambiance -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[140px]"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-blue-600/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">

        <!-- Section header -->
        <div class="mb-16">
            <div class="[font-family:'Space_Mono',monospace] text-[0.65rem] tracking-[0.18em] inline-flex items-center gap-[0.3rem] mb-5">
                <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">[</span>
                <span class="text-[rgba(34,211,238,0.85)]">skills.log</span>
                <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">]</span>
            </div>
            <h2 data-i18n="skills.title"
                class="[font-family:'Barlow_Condensed',sans-serif] font-black text-[clamp(2.5rem,7vw,4.5rem)] uppercase [letter-spacing:-0.01em] [line-height:0.95] text-white mb-5">
                Technical <span class="italic text-[#22d3ee]">Skills</span>
            </h2>
            <p data-i18n="skills.subtitle"
               class="[font-family:'Space_Mono',monospace] text-[0.72rem] text-[rgba(100,116,139,0.85)] max-w-[360px] leading-[1.8] tracking-[0.02em]">
                Tools and technologies I work with daily.
            </p>
        </div>

        <!-- Skills grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {skillCategories.map((category, index) => (
                <div class="group relative bg-gradient-to-br from-white/[0.04] to-transparent border border-white/[0.08] rounded-2xl p-8 hover:border-white/[0.14] transition-all duration-500 hover:shadow-xl hover:shadow-black/30 cursor-default overflow-hidden">

                    <!-- Background index number -->
                    <span class="absolute top-5 right-7 font-display text-7xl font-extrabold text-white/[0.035] group-hover:text-primary/[0.07] transition-colors duration-500 select-none leading-none pointer-events-none">
                        {String(index + 1).padStart(2, '0')}
                    </span>

                    <!-- Icon + Title -->
                    <div class="flex items-center gap-4 mb-7">
                        <div class={`flex-shrink-0 w-11 h-11 flex items-center justify-center rounded-xl border transition-all duration-300 ${category.accent}`}>
                            <i class={`${category.icon} text-lg`}></i>
                        </div>
                        <div>
                            <h3 data-i18n={category.i18nKey}
                                class="text-lg font-bold text-white">
                                {category.title}
                            </h3>
                            <div class="w-6 h-0.5 bg-primary/40 mt-1.5 group-hover:w-14 group-hover:bg-primary/70 transition-all duration-500"></div>
                        </div>
                    </div>

                    <!-- Skill tags -->
                    <div class="flex flex-wrap gap-2">
                        {category.skills.map((skill) => (
                            <span class="inline-flex items-center px-3.5 py-1.5 text-sm text-slate-300 font-medium rounded-lg bg-white/[0.04] border border-white/[0.07] hover:border-primary/30 hover:text-white hover:bg-primary/5 transition-all duration-200">
                                {skill}
                            </span>
                        ))}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
