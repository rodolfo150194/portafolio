---
const skillCategories = [
    {
        i18nKey: "skills.cat.0",
        title: "Backend",
        icon: "fa-solid fa-terminal",
        accent: "text-emerald-400 bg-emerald-400/10 border-emerald-400/20",
        skills: ["Python", "Django", "FastAPI", "ASP.NET", "C#", "APIs REST"]
    },
    {
        i18nKey: "skills.cat.1",
        title: "Frontend",
        icon: "fa-solid fa-globe",
        accent: "text-blue-400 bg-blue-400/10 border-blue-400/20",
        skills: ["Next.js", "Astro","Flutter", "TypeScript", "TailwindCSS"]
    },
    {
        i18nKey: "skills.cat.2",
        title: "QA & Testing",
        icon: "fa-solid fa-flask-vial",
        accent: "text-rose-400 bg-rose-400/10 border-rose-400/20",
        skills: ["Pytest", "Selenium", "Playwright", "Postman", "Testing funcional", "Regresión", "Casos de prueba", "Pruebas de integración", "UAT", "Jira / GitHub Issues"]
    },
    {
        i18nKey: "skills.cat.3",
        title: "Databases",
        icon: "fa-solid fa-database",
        accent: "text-amber-400 bg-amber-400/10 border-amber-400/20",
        skills: ["PostgreSQL", "MySQL", "SQL Server"]
    },
    {
        i18nKey: "skills.cat.4",
        title: "DevOps & Control",
        icon: "fa-solid fa-code-branch",
        accent: "text-violet-400 bg-violet-400/10 border-violet-400/20",
        skills: ["Git", "GitHub", "CI/CD", "Backups", "Docker", "VPS Management", "Cloud (AWS, Azure)"]
    },
    {
        i18nKey: "skills.cat.5",
        title: "Infraestructura",
        icon: "fa-solid fa-server",
        accent: "text-orange-400 bg-orange-400/10 border-orange-400/20",
        skills: ["LAN / WAN", "Linux", "Windows Server", "Active Directory"]
    },
    {
        i18nKey: "skills.cat.6",
        title: "GIS & Datos",
        icon: "fa-solid fa-map-location-dot",
        accent: "text-teal-400 bg-teal-400/10 border-teal-400/20",
        skills: ["Leaflet", "GeoServer", "Visualización geoespacial"]
    },
    {
        i18nKey: "skills.cat.7",
        title: "IA Aplicada",
        icon: "fa-solid fa-robot",
        accent: "text-cyan-400 bg-cyan-400/10 border-cyan-400/20",
        skills: ["AI-Assisted Development", "GitHub Copilot", "Cursor", "Claude Code", "Prompt Engineering"]
    }
];
---

<section id="habilidades" class="relative py-24 bg-white dark:bg-gray-950 overflow-hidden">

    <!-- Background ambiance -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[140px]"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-blue-600/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">

        <!-- Section header -->
        <div class="mb-16 text-center">
            <div class="[font-family:'Space_Mono',monospace] text-[0.65rem] tracking-[0.18em] inline-flex items-center gap-[0.3rem] mb-5">
                <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">[</span>
                <span class="text-[rgba(34,211,238,0.85)]">skills.log</span>
                <span class="text-[rgba(34,211,238,0.55)] text-[1rem] leading-none">]</span>
            </div>
            <h2 class="[font-family:'Barlow_Condensed',sans-serif] font-black text-[clamp(2.5rem,7vw,4.5rem)] uppercase [letter-spacing:-0.01em] [line-height:0.95] text-gray-900 dark:text-white mb-5">
                <span data-i18n="skills.title.1" style="color: transparent; -webkit-text-stroke: 2px #22d3ee;">Technical</span>
                <span data-i18n="skills.title.2" class="italic">Skills</span>
            </h2>
            <p data-i18n="skills.subtitle"
               class="[font-family:'Space_Mono',monospace] text-[0.72rem] text-[rgba(100,116,139,0.85)] max-w-[360px] mx-auto leading-[1.8] tracking-[0.02em]">
                Tools and technologies I work with daily.
            </p>
        </div>

        <!-- Skills grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {skillCategories.map((category, index) => (
                <div class="group relative bg-gradient-to-br from-gray-100 dark:from-white/[0.04] to-transparent border border-gray-200 dark:border-white/[0.08] rounded-2xl p-8 hover:border-gray-300 dark:hover:border-white/[0.14] transition-all duration-500 hover:shadow-xl hover:shadow-black/10 dark:hover:shadow-black/30 cursor-default overflow-hidden">

                    <!-- Background index number -->
                    <span class="absolute top-5 right-7 [font-family:'Barlow_Condensed',sans-serif] font-black text-7xl uppercase text-white/[0.035] group-hover:text-primary/[0.07] transition-colors duration-500 select-none leading-none pointer-events-none">
                        {String(index + 1).padStart(2, '0')}
                    </span>

                    <!-- Icon + Title -->
                    <div class="flex items-center gap-4 mb-7">
                        <div class={`flex-shrink-0 w-11 h-11 flex items-center justify-center rounded-xl border transition-all duration-300 ${category.accent}`}>
                            <i class={`${category.icon} text-lg`}></i>
                        </div>
                        <div>
                            <h3 data-i18n={category.i18nKey}
                                class="[font-family:'Barlow_Condensed',sans-serif] font-extrabold text-[1.15rem] uppercase tracking-[0.04em] text-gray-900 dark:text-white">
                                {category.title}
                            </h3>
                            <div class="w-6 h-0.5 bg-primary/40 mt-1.5 group-hover:w-14 group-hover:bg-primary/70 transition-all duration-500"></div>
                        </div>
                    </div>

                    <!-- Skill tags -->
                    <div class="flex flex-wrap gap-2">
                        {category.skills.map((skill) => (
                            <span class="inline-flex items-center px-3.5 py-1.5 text-sm text-gray-700 dark:text-slate-300 font-medium rounded-lg bg-gray-100 dark:bg-white/[0.04] border border-gray-200 dark:border-white/[0.07] hover:border-primary/30 hover:text-gray-900 dark:hover:text-white hover:bg-primary/5 transition-all duration-200">
                                {skill}
                            </span>
                        ))}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
